<refentry xml:id="function.ps-begin-glyph" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>ps_begin_glyph</refname>
  <refpurpose>Starts a new glyph definition</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type>bool</type><methodname>ps_begin_glyph</methodname>
   <methodparam><type>resource</type><parameter>psdoc</parameter></methodparam>
   <methodparam><type>string</type><parameter>glyphname</parameter></methodparam>
   <methodparam><type>float</type><parameter>wx</parameter></methodparam>
   <methodparam><type>float</type><parameter>llx</parameter></methodparam>
   <methodparam><type>float</type><parameter>lly</parameter></methodparam>
   <methodparam><type>float</type><parameter>urx</parameter></methodparam>
   <methodparam><type>float</type><parameter>ury</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Starts a new glyph definition. This function is only available when pslib has been built with
   font support.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <para>
   <variablelist>
    <varlistentry>
     <term><parameter>psdoc</parameter></term>
     <listitem>
      <simpara>
       Resource identifier of the postscript file as returned by <function>ps_new</function>.
      </simpara>
     </listitem>
    </varlistentry>
    <varlistentry>
     <term><parameter>glyphname</parameter></term>
     <listitem>
      <simpara>
       The name of the glyph.
      </simpara>
     </listitem>
    </varlistentry>
    <varlistentry>
     <term><parameter>wx</parameter></term>
     <listitem>
      <simpara>
       The width of the glyph.
      </simpara>
     </listitem>
    </varlistentry>
    <varlistentry>
     <term><parameter>llx</parameter></term>
     <listitem>
      <simpara>
       Lower left x coordinate of the glyph bounding box.
      </simpara>
     </listitem>
    </varlistentry>
    <varlistentry>
     <term><parameter>lly</parameter></term>
     <listitem>
      <simpara>
       Lower left y coordinate of the glyph bounding box.
      </simpara>
     </listitem>
    </varlistentry>
    <varlistentry>
     <term><parameter>urx</parameter></term>
     <listitem>
      <simpara>
       Upper right x coordinate of the glyph bounding box.
      </simpara>
     </listitem>
    </varlistentry>
    <varlistentry>
     <term><parameter>ury</parameter></term>
     <listitem>
      <simpara>
       Upper right y coordinate of the glyph bounding box.
      </simpara>
     </listitem>
    </varlistentry>
   </variablelist>
  </para>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   &return.success;
  </simpara>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
    <member><function>ps_end_glyph</function></member>
    <member><function>ps_begin_font</function></member>
  </simplelist>
 </refsect1>
</refentry>
