    </tbody>
   </tgroup>
  </informaltable>
 </refsect1>

 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>enchant_dict_add_to_session</function></member>
   <member><function>enchant_dict_remove</function></member>
  </simplelist>
 </refsect1>
</refentry>
