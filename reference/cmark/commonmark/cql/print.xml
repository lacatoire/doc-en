<refentry xml:id="commonmark-cql.print" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>CommonMark\CQL::print</refname>
  <refpurpose>Print the compiled CQL</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>void</type><methodname>CommonMark\CQL::print</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Shall print a disassembly of the compiled CQL function to the standard output.
   The dump reports the size of the compiled function and of its stack, followed by
   the list of operations that make up the query, and is intended as a debugging aid.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   &return.void;
  </simpara>
 </refsect1>

</refentry>
