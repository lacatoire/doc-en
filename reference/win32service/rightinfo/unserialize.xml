<refentry xml:id="win32service-rightinfo.unserialize" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Win32Service\RightInfo::__unserialize</refname>
  <refpurpose>Restore the RightInfo from serialized data</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>final</modifier> <modifier>public</modifier> <type>void</type> <methodname>Win32Service\RightInfo::__unserialize</methodname>
   <methodparam><type>array</type><parameter>data</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Restore the <classname>Win32Service\RightInfo</classname> object state from
   the serialized data produced by
   <function>Win32Service\RightInfo::__serialize</function>.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <para>
   <variablelist>
    <varlistentry>
     <term><parameter>data</parameter></term>
     <listitem>
      <simpara>
       The serialized data, containing the keys <literal>domain</literal>,
       <literal>username</literal>, <literal>mask</literal> and
       <literal>accessMode</literal>.
      </simpara>
     </listitem>
    </varlistentry>
   </variablelist>
  </para>
 </refsect1>

 <refsect1 role="returnvalues"><!-- {{{ -->
  &reftitle.returnvalues;
  <simpara>&return.void;</simpara>
 </refsect1><!-- }}} -->

 <refsect1 role="errors">
  &reftitle.errors;
  <para>
   Throws a <exceptionname>Win32ServiceException</exceptionname> when a required
   key is missing or has an invalid type.
  </para>
 </refsect1>

 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>Win32Service\RightInfo::__serialize</function></member>
   <member><function>Win32Service\RightInfo::getRights</function></member>
   <member><function>Win32Service\RightInfo::isGrantAccess</function></member>
   <member><function>Win32Service\RightInfo::isDenyAccess</function></member>
   <member><function>Win32Service\RightInfo::getFullUsername</function></member>
   <member><function>Win32Service\RightInfo::getUsername</function></member>
   <member><function>Win32Service\RightInfo::getDomain</function></member>
  </simplelist>
 </refsect1>

</refentry>

