<refentry xml:id="function.win32-exists-service" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>win32_exists_service</refname>
  <refpurpose>Checks whether a service exists</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type>bool</type><methodname>win32_exists_service</methodname>
   <methodparam><type>string</type><parameter>servicename</parameter></methodparam>
   <methodparam choice="opt"><type>string</type><parameter>machine</parameter><initializer>""</initializer></methodparam>
  </methodsynopsis>
  <simpara>
   Checks whether a service entry exists in the SCM database.
   Administrative privileges are required for this to succeed.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <para>
   <variablelist>
    <varlistentry>
     <term><parameter>servicename</parameter></term>
     <listitem>
      <simpara>
       The short name of the service.
      </simpara>
     </listitem>
    </varlistentry>
    <varlistentry>
     <term><parameter>machine</parameter></term>
     <listitem>
      <simpara>
       The optional machine name. If omitted, the local machine is used.
      </simpara>
     </listitem>
    </varlistentry>
   </variablelist>
  </para>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; if the service exists, &false; otherwise.
  </simpara>
 </refsect1>

 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   A <exceptionname>ValueError</exceptionname> is thrown if the
   value of <parameter>servicename</parameter> parameter is empty.
  </simpara>
  <simpara>
   A <exceptionname>Win32ServiceException</exceptionname> is thrown on error.
  </simpara>
 </refsect1>

 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>win32_create_service</function></member>
   <member><function>win32_delete_service</function></member>
   <member><function>win32_query_service_status</function></member>
  </simplelist>
 </refsect1>

</refentry>

