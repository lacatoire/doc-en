<refentry xml:id="function.win32-exists-service" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>win32_exists_service</refname>
  <refpurpose>Checks whether a service exists in the SCM database</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type>bool</type><methodname>win32_exists_service</methodname>
   <methodparam><type>string</type><parameter>servicename</parameter></methodparam>
   <methodparam choice="opt"><type>string</type><parameter>machine</parameter><initializer>""</initializer></methodparam>
  </methodsynopsis>
  <simpara>
   Checks whether a service is registered in the Service Control Manager
   database.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>servicename</parameter></term>
    <listitem>
     <simpara>
      The short name of the service.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>machine</parameter></term>
    <listitem>
     <simpara>
      The optional machine name. If omitted, the local machine is used.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; if the service exists, or &false; otherwise.
  </simpara>
 </refsect1>

</refentry>

