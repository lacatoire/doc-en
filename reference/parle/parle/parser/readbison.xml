<refentry xml:id="parle-parser.readbison" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Parle\Parser::readBison</refname>
  <refpurpose>Read a grammar in Bison format</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>void</type><methodname>Parle\Parser::readBison</methodname>
   <methodparam><type>string</type><parameter>input</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Reads a complete grammar in the Bison format from <parameter>input</parameter>
   and loads it into the parser. Any rules previously added to the parser are
   discarded and replaced by the grammar contained in
   <parameter>input</parameter>. An invalid grammar causes a
   <exceptionname>Parle\ParserException</exceptionname> to be thrown.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>input</parameter></term>
    <listitem>
     <simpara>
      The grammar to read, in Bison compatible syntax.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   &return.void;
  </simpara>
 </refsect1>

 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><methodname>Parle\Parser::push</methodname></member>
   <member><methodname>Parle\Parser::build</methodname></member>
  </simplelist>
 </refsect1>

</refentry>

