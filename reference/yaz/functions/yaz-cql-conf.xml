<refentry xml:id="function.yaz-cql-conf" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>yaz_cql_conf</refname>
  <refpurpose>Configure CQL parser</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type>void</type><methodname>yaz_cql_conf</methodname>
   <methodparam><type>resource</type><parameter>id</parameter></methodparam>
   <methodparam><type>array</type><parameter>package</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   This function configures the CQL query parser for a server with definitions
   of access points and their mapping to RPN. It is the CQL counterpart of
   <function>yaz_ccl_conf</function>.
  </simpara>
  <simpara>
   To map a specific CQL query to RPN afterwards call the
   <function>yaz_cql_parse</function> function.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <para>
   <variablelist>
    <varlistentry>
     <term><parameter>id</parameter></term>
     <listitem>
      <simpara>
       The connection resource returned by <function>yaz_connect</function>.
      </simpara>
     </listitem>
    </varlistentry>
    <varlistentry>
     <term><parameter>package</parameter></term>
     <listitem>
      <simpara>
       An array of configuration. Each key of the array is the name of a CQL
       transform property and the corresponding value holds a string that
       specifies a mapping to RPN.
      </simpara>
     </listitem>
    </varlistentry>
   </variablelist>
  </para>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   &return.void;
  </simpara>
 </refsect1>
 <refsect1 role="notes">
  &reftitle.notes;
  <note>
   <simpara>
    This function is only available when the extension is built against YAZ
    5.1.0 or later.
   </simpara>
  </note>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>yaz_cql_parse</function></member>
   <member><function>yaz_ccl_conf</function></member>
  </simplelist>
 </refsect1>
</refentry>
