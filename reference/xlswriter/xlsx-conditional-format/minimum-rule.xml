<refentry xml:id="vtiful-kernel-conditionalformat.minimumRule" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\ConditionalFormat::minimumRule</refname>
  <refpurpose>Vtiful\Kernel\ConditionalFormat minimumRule</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Vtiful\Kernel\ConditionalFormat</type> <methodname>Vtiful\Kernel\ConditionalFormat::minimumRule</methodname>
   <methodparam><type>int</type><parameter>value</parameter></methodparam>
  </methodsynopsis>
  <simpara>Sets how the minimum point is interpreted for color scale and data bar rules, using one of the <constant>RULE_*</constant> class constants.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>value</parameter></term>
    <listitem>
     <simpara>One of the <constant>Vtiful\Kernel\ConditionalFormat::RULE_*</constant> constants describing how the minimum is calculated.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the current <classname>Vtiful\Kernel\ConditionalFormat</classname> instance, allowing method calls to be chained.</simpara>
 </refsect1>
</refentry>
