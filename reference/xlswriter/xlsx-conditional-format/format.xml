<refentry xml:id="vtiful-kernel-conditionalformat.format" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\ConditionalFormat::format</refname>
  <refpurpose>Vtiful\Kernel\ConditionalFormat format</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Vtiful\Kernel\ConditionalFormat</type> <methodname>Vtiful\Kernel\ConditionalFormat::format</methodname>
   <methodparam><type>Vtiful\Kernel\Format</type><parameter>format</parameter></methodparam>
  </methodsynopsis>
  <simpara>Sets the cell format that is applied to the cells matched by the conditional format rule.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>format</parameter></term>
    <listitem>
     <simpara>A <classname>Vtiful\Kernel\Format</classname> instance, or the format resource returned by its <literal>toResource()</literal> method, describing the style to apply when the condition is met.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the current <classname>Vtiful\Kernel\ConditionalFormat</classname> instance for method chaining.</simpara>
 </refsect1>
</refentry>
