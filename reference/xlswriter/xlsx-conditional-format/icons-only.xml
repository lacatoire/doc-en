<refentry xml:id="vtiful-kernel-conditionalformat.iconsOnly" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\ConditionalFormat::iconsOnly</refname>
  <refpurpose>Vtiful\Kernel\ConditionalFormat iconsOnly</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Vtiful\Kernel\ConditionalFormat</type> <methodname>Vtiful\Kernel\ConditionalFormat::iconsOnly</methodname>
   <methodparam choice="opt"><type>bool</type><parameter>on</parameter></methodparam>
  </methodsynopsis>
  <simpara>Toggles whether only the icons of an icon set conditional format are shown, hiding the underlying cell values.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>on</parameter></term>
    <listitem>
     <simpara>Whether to display icons only. Defaults to &true;.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the current <classname>Vtiful\Kernel\ConditionalFormat</classname> instance, allowing method chaining.</simpara>
 </refsect1>
</refentry>
