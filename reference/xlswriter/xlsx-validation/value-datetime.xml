<refentry xml:id="vtiful-kernel-validation.valueDatetime" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Validation::valueDatetime</refname>
  <refpurpose>Vtiful\Kernel\Validation valueDatetime</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>void</type> <methodname>Vtiful\Kernel\Validation::valueDatetime</methodname>
   <methodparam><type>int</type><parameter>timestamp</parameter></methodparam>
  </methodsynopsis>
  <simpara>Sets the value used by the data validation rule as a date and time, converted from a Unix timestamp.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>timestamp</parameter></term>
    <listitem>
     <simpara>A Unix timestamp that is converted to the date and time compared against the cell contents.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>No value is returned.</simpara>
 </refsect1>
</refentry>
