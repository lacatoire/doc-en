<refentry xml:id="vtiful-kernel-validation.inputTitle" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Validation::inputTitle</refname>
  <refpurpose>Vtiful\Kernel\Validation inputTitle</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Vtiful\Kernel\Validation</type> <methodname>Vtiful\Kernel\Validation::inputTitle</methodname>
   <methodparam><type>string</type><parameter>input_title</parameter></methodparam>
  </methodsynopsis>
  <simpara>Sets the title of the input message shown when a cell governed by this data validation rule is selected.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>input_title</parameter></term>
    <listitem>
     <simpara>The title text of the input prompt displayed when the cell is selected.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the current <classname>Vtiful\Kernel\Validation</classname> instance, allowing method calls to be chained.</simpara>
 </refsect1>
</refentry>
