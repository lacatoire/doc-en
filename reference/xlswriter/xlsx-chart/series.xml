<refentry xml:id="vtiful-kernel-chart.series" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Chart::series</refname>
  <refpurpose>Vtiful\Kernel\Chart series</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Vtiful\Kernel\Chart</type> <methodname>Vtiful\Kernel\Chart::series</methodname>
   <methodparam><type>string</type><parameter>value</parameter></methodparam>
   <methodparam choice="opt"><type>string</type><parameter>categories</parameter></methodparam>
  </methodsynopsis>
  <simpara>Adds a data series to the chart, using the given cell range for the values and, optionally, another range for the categories.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>value</parameter></term>
    <listitem>
     <simpara>The cell range holding the series values, for example <literal>Sheet1!$A$1:$A$5</literal>.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>categories</parameter></term>
    <listitem>
     <simpara>The cell range holding the series categories. When omitted, the series has no explicit categories.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the current <classname>Vtiful\Kernel\Chart</classname> instance, allowing method calls to be chained.</simpara>
 </refsect1>
</refentry>
