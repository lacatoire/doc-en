<refentry xml:id="vtiful-kernel-chart.legendSetPosition" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Chart::legendSetPosition</refname>
  <refpurpose>Vtiful\Kernel\Chart legendSetPosition</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Vtiful\Kernel\Chart</type> <methodname>Vtiful\Kernel\Chart::legendSetPosition</methodname>
   <methodparam><type>int</type><parameter>type</parameter></methodparam>
  </methodsynopsis>
  <simpara>Sets the position of the chart legend relative to the plot area.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>type</parameter></term>
    <listitem>
     <simpara>The legend position, given as one of the <literal>CHART_LEGEND_*</literal> constants defined on <classname>Vtiful\Kernel\Chart</classname>.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the current <classname>Vtiful\Kernel\Chart</classname> instance, allowing method calls to be chained.</simpara>
 </refsect1>
</refentry>
