<refentry xml:id="vtiful-kernel-chart.__construct" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Chart::__construct</refname>
  <refpurpose>Vtiful\Kernel\Chart __construct</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Vtiful\Kernel\Chart</type> <methodname>Vtiful\Kernel\Chart::__construct</methodname>
   <methodparam><type>resource</type><parameter>handle</parameter></methodparam>
   <methodparam><type>int</type><parameter>type</parameter></methodparam>
  </methodsynopsis>
  <simpara>Creates a new chart of the given type bound to the workbook referenced by the resource handle.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>handle</parameter></term>
    <listitem>
     <simpara>The workbook resource handle the chart is attached to.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>type</parameter></term>
    <listitem>
     <simpara>The chart type, given as one of the <literal>CHART_*</literal> constants defined on <classname>Vtiful\Kernel\Chart</classname>.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the newly created <classname>Vtiful\Kernel\Chart</classname> instance.</simpara>
 </refsect1>
</refentry>
