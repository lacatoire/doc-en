<refentry xml:id="vtiful-kernel-excel.nextCellCallback" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Excel::nextCellCallback</refname>
  <refpurpose>Vtiful\Kernel\Excel nextCellCallback</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>void</type> <methodname>Vtiful\Kernel\Excel::nextCellCallback</methodname>
   <methodparam><type>callable</type><parameter>fci</parameter></methodparam>
   <methodparam choice="opt"><type>string</type><parameter>sheet_name</parameter></methodparam>
  </methodsynopsis>
  <simpara>Streams the cells of a worksheet, invoking the given callback for each cell as it is read instead of buffering the whole sheet in memory.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>fci</parameter></term>
    <listitem>
     <simpara>The callback invoked for each cell, receiving the cell value together with its row and column position.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>sheet_name</parameter></term>
    <listitem>
     <simpara>The name of the worksheet to stream. When omitted, the currently opened sheet is used.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>No value is returned. The method returns &false; when no file is open.</simpara>
 </refsect1>
</refentry>
