<refentry xml:id="vtiful-kernel-excel.outlineSettings" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Excel::outlineSettings</refname>
  <refpurpose>Vtiful\Kernel\Excel outlineSettings</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Vtiful\Kernel\Excel</type> <methodname>Vtiful\Kernel\Excel::outlineSettings</methodname>
   <methodparam choice="opt"><type>bool</type><parameter>visible</parameter></methodparam>
   <methodparam choice="opt"><type>bool</type><parameter>below</parameter></methodparam>
   <methodparam choice="opt"><type>bool</type><parameter>right</parameter></methodparam>
   <methodparam choice="opt"><type>bool</type><parameter>auto_style</parameter></methodparam>
  </methodsynopsis>
  <simpara>Configures the outline and grouping settings of the worksheet.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>visible</parameter></term>
    <listitem>
     <simpara>Whether the outline symbols are visible.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>below</parameter></term>
    <listitem>
     <simpara>Whether the summary rows are placed below the detail rows.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>right</parameter></term>
    <listitem>
     <simpara>Whether the summary columns are placed to the right of the detail columns.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>auto_style</parameter></term>
    <listitem>
     <simpara>Whether the automatic outline style is applied.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the current <classname>Vtiful\Kernel\Excel</classname> instance.</simpara>
 </refsect1>
</refentry>
