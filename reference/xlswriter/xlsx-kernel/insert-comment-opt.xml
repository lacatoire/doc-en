<refentry xml:id="vtiful-kernel-excel.insertCommentOpt" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Excel::insertCommentOpt</refname>
  <refpurpose>Vtiful\Kernel\Excel insertCommentOpt</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Vtiful\Kernel\Excel</type> <methodname>Vtiful\Kernel\Excel::insertCommentOpt</methodname>
   <methodparam><type>int</type><parameter>row</parameter></methodparam>
   <methodparam><type>int</type><parameter>column</parameter></methodparam>
   <methodparam><type>string</type><parameter>text</parameter></methodparam>
   <methodparam><type>array</type><parameter>options</parameter></methodparam>
  </methodsynopsis>
  <simpara>Inserts a comment at the given cell with additional display options.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>row</parameter></term>
    <listitem>
     <simpara>The zero-based row index of the cell.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>column</parameter></term>
    <listitem>
     <simpara>The zero-based column index of the cell.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>text</parameter></term>
    <listitem>
     <simpara>The comment text.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>options</parameter></term>
    <listitem>
     <simpara>An associative array of comment options, such as author, font_name, font_size, color, x_offset, y_offset, x_scale, y_scale, visible, width and height.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the current <classname>Vtiful\Kernel\Excel</classname> instance.</simpara>
 </refsect1>
</refentry>
