<refentry xml:id="vtiful-kernel-excel.conditionalFormatCell" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Excel::conditionalFormatCell</refname>
  <refpurpose>Vtiful\Kernel\Excel conditionalFormatCell</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Vtiful\Kernel\Excel</type> <methodname>Vtiful\Kernel\Excel::conditionalFormatCell</methodname>
   <methodparam><type>string</type><parameter>range</parameter></methodparam>
   <methodparam><type>Vtiful\Kernel\ConditionalFormat</type><parameter>conditional_format</parameter></methodparam>
  </methodsynopsis>
  <simpara>Applies a conditional format to a single cell identified by an A1-style reference.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>range</parameter></term>
    <listitem>
     <simpara>The target cell in A1 notation, for example <literal>A1</literal>.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>conditional_format</parameter></term>
    <listitem>
     <simpara>A <classname>Vtiful\Kernel\ConditionalFormat</classname> instance describing the conditional formatting rule to apply.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the current <classname>Vtiful\Kernel\Excel</classname> instance, allowing method chaining.</simpara>
 </refsect1>
</refentry>
