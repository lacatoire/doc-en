<refentry xml:id="vtiful-kernel-excel.putCSV" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Excel::putCSV</refname>
  <refpurpose>Vtiful\Kernel\Excel putCSV</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>Vtiful\Kernel\Excel::putCSV</methodname>
   <methodparam><type>resource</type><parameter>fp</parameter></methodparam>
   <methodparam choice="opt"><type>string</type><parameter>delimiter_str</parameter></methodparam>
   <methodparam choice="opt"><type>string</type><parameter>enclosure_str</parameter></methodparam>
   <methodparam choice="opt"><type>string</type><parameter>escape_str</parameter></methodparam>
  </methodsynopsis>
  <simpara>Writes the currently opened worksheet to the given file handle as CSV data.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>fp</parameter></term>
    <listitem>
     <simpara>An open file handle that the CSV data is written to.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>delimiter_str</parameter></term>
    <listitem>
     <simpara>The field delimiter character.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>enclosure_str</parameter></term>
    <listitem>
     <simpara>The field enclosure character.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>escape_str</parameter></term>
    <listitem>
     <simpara>The escape character.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns &true; on success, or &false; on failure.</simpara>
 </refsect1>
</refentry>
