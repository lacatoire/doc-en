<refentry xml:id="vtiful-kernel-excel.getStyleFormat" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Excel::getStyleFormat</refname>
  <refpurpose>Vtiful\Kernel\Excel getStyleFormat</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>array</type> <methodname>Vtiful\Kernel\Excel::getStyleFormat</methodname>
   <methodparam><type>int</type><parameter>style_id</parameter></methodparam>
  </methodsynopsis>
  <simpara>Returns the resolved cell style definition for the given style index of the opened workbook.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>style_id</parameter></term>
    <listitem>
     <simpara>The zero-based index of the cell format (xf) record to look up.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns an associative array describing the style, including keys such as <literal>num_fmt_id</literal>, <literal>category</literal>, <literal>format_string</literal>, <literal>font_id</literal>, <literal>fill_id</literal>, <literal>border_id</literal>, <literal>alignment</literal> and <literal>protection</literal>, or &null; when no workbook is open or the style index does not exist.</simpara>
 </refsect1>
</refentry>
