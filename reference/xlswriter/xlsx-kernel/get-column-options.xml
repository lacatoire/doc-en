<refentry xml:id="vtiful-kernel-excel.getColumnOptions" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Excel::getColumnOptions</refname>
  <refpurpose>Vtiful\Kernel\Excel getColumnOptions</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>array</type><methodname>Vtiful\Kernel\Excel::getColumnOptions</methodname>
   <methodparam><type>string</type><parameter>colA1</parameter></methodparam>
  </methodsynopsis>
  <simpara>Returns the metadata associated with a column of the currently opened worksheet.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>colA1</parameter></term>
    <listitem>
     <simpara>The A1-style column letter, for example <literal>A</literal> or <literal>AB</literal>.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns an associative array with the keys <literal>width</literal>, <literal>hidden</literal>, <literal>outline_level</literal> and <literal>collapsed</literal>, or &null; when the column has no metadata or no worksheet is open.</simpara>
 </refsect1>
</refentry>
