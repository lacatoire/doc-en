<refentry xml:id="vtiful-kernel-excel.setCustomProperty" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Excel::setCustomProperty</refname>
  <refpurpose>Vtiful\Kernel\Excel setCustomProperty</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Vtiful\Kernel\Excel</type> <methodname>Vtiful\Kernel\Excel::setCustomProperty</methodname>
   <methodparam><type>string</type><parameter>name</parameter></methodparam>
   <methodparam><type>mixed</type><parameter>value</parameter></methodparam>
   <methodparam choice="opt"><type class="union"><type>string</type><type>null</type></type><parameter>type</parameter></methodparam>
  </methodsynopsis>
  <simpara>Sets a custom document property for the workbook. Custom properties allow arbitrary named metadata to be stored in the file.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>name</parameter></term>
    <listitem>
     <simpara>The name of the custom property.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>value</parameter></term>
    <listitem>
     <simpara>The value of the custom property. Depending on <parameter>type</parameter>, it is interpreted as a string, number, boolean, or datetime timestamp.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>type</parameter></term>
    <listitem>
     <simpara>The property type, one of <literal>string</literal>, <literal>number</literal>, <literal>boolean</literal> or <literal>datetime</literal>. When &null;, the type is inferred from the PHP type of <parameter>value</parameter>.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the current <classname>Vtiful\Kernel\Excel</classname> instance, allowing method chaining.</simpara>
 </refsect1>
</refentry>
