<refentry xml:id="vtiful-kernel-excel.getSheetProtection" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Excel::getSheetProtection</refname>
  <refpurpose>Vtiful\Kernel\Excel getSheetProtection</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>array</type><methodname>Vtiful\Kernel\Excel::getSheetProtection</methodname>
   <void/>
  </methodsynopsis>
  <simpara>Returns the sheet protection settings of the currently opened worksheet.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns an associative array holding the <literal>password_hash</literal> and the individual protection flags (such as <literal>sheet</literal>, <literal>content</literal>, <literal>objects</literal> and <literal>format_cells</literal>), or &null; when the worksheet is not protected or no worksheet is open.</simpara>
 </refsect1>
</refentry>
