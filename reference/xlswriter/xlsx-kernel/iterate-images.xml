<refentry xml:id="vtiful-kernel-excel.iterateImages" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Excel::iterateImages</refname>
  <refpurpose>Vtiful\Kernel\Excel iterateImages</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type> <methodname>Vtiful\Kernel\Excel::iterateImages</methodname>
   <methodparam><type>callable</type><parameter>callback</parameter></methodparam>
   <methodparam choice="opt"><type>string</type><parameter>sheet_name</parameter></methodparam>
  </methodsynopsis>
  <simpara>Invokes the given callback once for every embedded image found in a worksheet.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>callback</parameter></term>
    <listitem>
     <simpara>The callback invoked for each image, receiving its position and payload data.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>sheet_name</parameter></term>
    <listitem>
     <simpara>The name of the worksheet to scan. When omitted, the currently opened sheet, or the first sheet, is used.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns &true; on success, or &false; when no workbook is open or the named sheet cannot be found.</simpara>
 </refsect1>
</refentry>
