<refentry xml:id="vtiful-kernel-excel.nextRowWithFormula" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Excel::nextRowWithFormula</refname>
  <refpurpose>Vtiful\Kernel\Excel nextRowWithFormula</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>array</type> <methodname>Vtiful\Kernel\Excel::nextRowWithFormula</methodname>
   <void/>
  </methodsynopsis>
  <simpara>Reads the next row from the currently opened sheet, exposing each cell together with its formula and hyperlink metadata rather than only its computed value.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the next row as an array of cell entries, or &null; when no sheet is open or the end of the sheet has been reached.</simpara>
 </refsect1>
</refentry>
