<refentry xml:id="vtiful-kernel-excel.timestampFromDateDouble" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Excel::timestampFromDateDouble</refname>
  <refpurpose>Vtiful\Kernel\Excel timestampFromDateDouble</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>int</type><methodname>Vtiful\Kernel\Excel::timestampFromDateDouble</methodname>
   <methodparam><type>float</type><parameter>index</parameter></methodparam>
  </methodsynopsis>
  <simpara>Converts an Excel serial date value into a Unix timestamp, using the 1900 date system.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>index</parameter></term>
    <listitem>
     <simpara>The Excel serial date value to convert.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the Unix timestamp corresponding to the given serial date, or <literal>0</literal> when the value is not positive.</simpara>
 </refsect1>
</refentry>
