<refentry xml:id="vtiful-kernel-excel.zoom" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Excel::zoom</refname>
  <refpurpose>Vtiful\Kernel\Excel zoom</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Vtiful\Kernel\Excel</type> <methodname>Vtiful\Kernel\Excel::zoom</methodname>
   <methodparam><type>int</type><parameter>scale</parameter></methodparam>
  </methodsynopsis>
  <simpara>Sets the display zoom level of the worksheet, as a percentage. The value is clamped to the 10 to 400 range.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>scale</parameter></term>
    <listitem>
     <simpara>Zoom level as a percentage, between <literal>10</literal> and <literal>400</literal>.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the current <classname>Vtiful\Kernel\Excel</classname> instance.</simpara>
 </refsect1>
</refentry>
