<refentry xml:id="vtiful-kernel-excel.defaultRowOptions" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Excel::defaultRowOptions</refname>
  <refpurpose>Vtiful\Kernel\Excel defaultRowOptions</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Vtiful\Kernel\Excel</type> <methodname>Vtiful\Kernel\Excel::defaultRowOptions</methodname>
   <methodparam choice="opt"><type>int</type><parameter>level</parameter></methodparam>
   <methodparam choice="opt"><type>bool</type><parameter>collapsed</parameter></methodparam>
   <methodparam choice="opt"><type>bool</type><parameter>hidden</parameter></methodparam>
  </methodsynopsis>
  <simpara>Sets the default outline options applied to worksheet rows.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>level</parameter></term>
    <listitem>
     <simpara>Outline level of the rows, from <literal>0</literal> to <literal>7</literal>.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>collapsed</parameter></term>
    <listitem>
     <simpara>Whether the rows are displayed as collapsed.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>hidden</parameter></term>
    <listitem>
     <simpara>Whether the rows are hidden.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the current <classname>Vtiful\Kernel\Excel</classname> instance.</simpara>
 </refsect1>
</refentry>
