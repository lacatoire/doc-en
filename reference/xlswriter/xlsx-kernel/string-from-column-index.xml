<refentry xml:id="vtiful-kernel-excel.stringFromColumnIndex" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Excel::stringFromColumnIndex</refname>
  <refpurpose>Vtiful\Kernel\Excel stringFromColumnIndex</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>string</type><methodname>Vtiful\Kernel\Excel::stringFromColumnIndex</methodname>
   <methodparam><type>int</type><parameter>index</parameter></methodparam>
  </methodsynopsis>
  <simpara>Converts a zero-based column index into its A1-style column letters (for example <literal>0</literal> becomes <literal>A</literal> and <literal>26</literal> becomes <literal>AA</literal>).</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>index</parameter></term>
    <listitem>
     <simpara>The zero-based column index to convert.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the A1-style column letters corresponding to the given index.</simpara>
 </refsect1>
</refentry>
