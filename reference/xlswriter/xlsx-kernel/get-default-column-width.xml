<refentry xml:id="vtiful-kernel-excel.getDefaultColumnWidth" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Excel::getDefaultColumnWidth</refname>
  <refpurpose>Vtiful\Kernel\Excel getDefaultColumnWidth</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>float</type><methodname>Vtiful\Kernel\Excel::getDefaultColumnWidth</methodname>
   <void/>
  </methodsynopsis>
  <simpara>Returns the default column width, in character units, of the worksheet currently open for reading.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>The default column width as a <type>float</type>, or &null; when no worksheet is open for reading or the value is not available.</simpara>
 </refsect1>
</refentry>
