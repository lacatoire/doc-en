<refentry xml:id="vtiful-kernel-excel.openSheet" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Excel::openSheet</refname>
  <refpurpose>Vtiful\Kernel\Excel openSheet</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Vtiful\Kernel\Excel</type><methodname>Vtiful\Kernel\Excel::openSheet</methodname>
   <methodparam choice="opt"><type>string</type><parameter>zs_sheet_name</parameter></methodparam>
   <methodparam choice="opt"><type>int</type><parameter>zl_flag</parameter></methodparam>
  </methodsynopsis>
  <simpara>Opens a worksheet from the currently opened workbook for reading. When no name is given, the first worksheet is opened.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>zs_sheet_name</parameter></term>
    <listitem>
     <simpara>The name of the worksheet to open. When omitted, the first worksheet is used.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>zl_flag</parameter></term>
    <listitem>
     <simpara>A flag controlling which rows are skipped while reading the worksheet.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the current <classname>Vtiful\Kernel\Excel</classname> instance.</simpara>
 </refsect1>
</refentry>
