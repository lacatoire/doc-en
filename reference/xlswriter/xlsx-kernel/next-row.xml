<refentry xml:id="vtiful-kernel-excel.nextRow" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Excel::nextRow</refname>
  <refpurpose>Vtiful\Kernel\Excel nextRow</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>array</type> <methodname>Vtiful\Kernel\Excel::nextRow</methodname>
   <methodparam choice="opt"><type>array</type><parameter>zv_type_t</parameter></methodparam>
  </methodsynopsis>
  <simpara>Reads the next row from the currently opened sheet, advancing the internal cursor by one row.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>zv_type_t</parameter></term>
    <listitem>
     <simpara>An optional array mapping column indexes to <classname>Vtiful\Kernel\Excel</classname> type constants used to decode this row. When omitted, the types configured with <function>Vtiful\Kernel\Excel::setType</function> are used.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the next row as an array of cell values, or &false; when no sheet is open.</simpara>
 </refsect1>
</refentry>
