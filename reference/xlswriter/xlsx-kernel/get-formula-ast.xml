<refentry xml:id="vtiful-kernel-excel.getFormulaAst" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Excel::getFormulaAst</refname>
  <refpurpose>Vtiful\Kernel\Excel getFormulaAst</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>array</type><methodname>Vtiful\Kernel\Excel::getFormulaAst</methodname>
   <methodparam><type>string</type><parameter>formula</parameter></methodparam>
  </methodsynopsis>
  <simpara>Parses a spreadsheet formula and returns its abstract syntax tree.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>formula</parameter></term>
    <listitem>
     <simpara>The formula expression to parse, with or without a leading equals sign.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>The parsed formula as a nested array representing the abstract syntax tree, where each node describes an operator, function call, cell reference or literal value.</simpara>
 </refsect1>
</refentry>
