<refentry xml:id="vtiful-kernel-richstring.__construct" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\RichString::__construct</refname>
  <refpurpose>Vtiful\Kernel\RichString __construct</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <methodname>Vtiful\Kernel\RichString::__construct</methodname>
   <methodparam><type>string</type><parameter>text</parameter></methodparam>
   <methodparam choice="opt"><type>resource</type><parameter>lxlsx_format_handle</parameter></methodparam>
  </methodsynopsis>
  <simpara>Builds a rich string fragment holding a piece of text together with an optional format, for use when writing a string composed of differently formatted runs.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>text</parameter></term>
    <listitem>
     <simpara>The text of the rich string fragment.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>lxlsx_format_handle</parameter></term>
    <listitem>
     <simpara>An optional format handle applied to this fragment, as returned by a <classname>Vtiful\Kernel\Format</classname> object. When omitted, the fragment inherits the default format.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns a new <classname>Vtiful\Kernel\RichString</classname> instance.</simpara>
 </refsect1>
</refentry>
