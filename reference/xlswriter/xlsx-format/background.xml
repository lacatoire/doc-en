<refentry xml:id="vtiful-kernel-format.background" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Format::background</refname>
  <refpurpose>Vtiful\Kernel\Format background</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Vtiful\Kernel\Format</type> <methodname>Vtiful\Kernel\Format::background</methodname>
   <methodparam><type>int</type><parameter>pattern</parameter></methodparam>
   <methodparam choice="opt"><type>int</type><parameter>color</parameter></methodparam>
  </methodsynopsis>
  <simpara>Sets the cell background color and fill pattern for the format.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>pattern</parameter></term>
    <listitem>
     <simpara>The background color, given as one of the color constants defined on <classname>Vtiful\Kernel\Format</classname> or as an RGB integer value.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>color</parameter></term>
    <listitem>
     <simpara>The fill pattern applied to the cell, given as one of the pattern constants defined on <classname>Vtiful\Kernel\Format</classname>. Defaults to a solid fill.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the current <classname>Vtiful\Kernel\Format</classname> instance, allowing method calls to be chained.</simpara>
 </refsect1>
</refentry>
