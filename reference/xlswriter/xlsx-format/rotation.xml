<refentry xml:id="vtiful-kernel-format.rotation" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Format::rotation</refname>
  <refpurpose>Vtiful\Kernel\Format rotation</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Vtiful\Kernel\Format</type> <methodname>Vtiful\Kernel\Format::rotation</methodname>
   <methodparam><type>int</type><parameter>angle</parameter></methodparam>
  </methodsynopsis>
  <simpara>Sets the rotation angle of the cell text.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>angle</parameter></term>
    <listitem>
     <simpara>The rotation angle in degrees, in the range -90 to 90, or 270 for stacked vertical text. Values outside this range are ignored.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the current <classname>Vtiful\Kernel\Format</classname> instance, allowing method chaining.</simpara>
 </refsect1>
</refentry>
