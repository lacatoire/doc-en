<refentry xml:id="vtiful-kernel-format.wrap" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Vtiful\Kernel\Format::wrap</refname>
  <refpurpose>Vtiful\Kernel\Format wrap</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Vtiful\Kernel\Format</type> <methodname>Vtiful\Kernel\Format::wrap</methodname>
   <void/>
  </methodsynopsis>
  <simpara>Enables text wrapping so that long cell content is displayed on multiple lines within the cell.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the current <classname>Vtiful\Kernel\Format</classname> instance, allowing method chaining.</simpara>
 </refsect1>
</refentry>
