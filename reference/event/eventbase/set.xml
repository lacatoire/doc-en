<refentry xml:id="eventbase.set" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>EventBase::set</refname>
  <refpurpose>Associates the event base with an event</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>EventBase::set</methodname>
   <methodparam><type>Event</type><parameter>event</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Associates the event base with the given <parameter>event</parameter>.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>event</parameter></term>
    <listitem>
     <simpara>
      The <classname>Event</classname> to associate with this event base.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   &return.success;
  </simpara>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><methodname>EventBase::__construct</methodname></member>
  </simplelist>
 </refsect1>
</refentry>
