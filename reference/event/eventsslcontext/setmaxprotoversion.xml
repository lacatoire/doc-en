<refentry xml:id="eventsslcontext.setmaxprotoversion" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>EventSslContext::setMaxProtoVersion</refname>
  <refpurpose>Sets the maximum supported protocol version</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>EventSslContext::setMaxProtoVersion</methodname>
   <methodparam><type>int</type><parameter>proto</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Sets the maximum supported SSL/TLS protocol version for the SSL context.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>proto</parameter></term>
    <listitem>
     <simpara>
      The maximum protocol version, one of the <constant>EventSslContext::SSL3_VERSION</constant>, <constant>EventSslContext::TLS1_VERSION</constant>, <constant>EventSslContext::TLS1_1_VERSION</constant>, <constant>EventSslContext::TLS1_2_VERSION</constant> constants. A value of <literal>0</literal> automatically selects the highest available version.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   &return.success;
  </simpara>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><methodname>EventSslContext::setMinProtoVersion</methodname></member>
  </simplelist>
 </refsect1>
</refentry>
