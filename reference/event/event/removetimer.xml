<refentry xml:id="event.removetimer" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Event::removeTimer</refname>
  <refpurpose>Removes a timer from a pending event</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>Event::removeTimer</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Removes a pending event's timeout completely, without deleting its I/O or signal components.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   &return.success;
  </simpara>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><methodname>Event::setTimer</methodname></member>
   <member><methodname>Event::del</methodname></member>
  </simplelist>
 </refsect1>
</refentry>
