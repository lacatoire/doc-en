<refentry xml:id="eventutil.createsocket" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>EventUtil::createSocket</refname>
  <refpurpose>Creates a Socket from a file descriptor</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <modifier>static</modifier> <type class="union"><type>Socket</type><type>false</type></type><methodname>EventUtil::createSocket</methodname>
   <methodparam><type>int</type><parameter>fd</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Creates a <classname>Socket</classname> object from a numeric file descriptor. Requires the <link linkend="book.sockets">Sockets</link> extension.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>fd</parameter></term>
    <listitem>
     <simpara>
      The numeric file descriptor.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns a <classname>Socket</classname> object, or &false; on failure.
  </simpara>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><methodname>EventUtil::getSocketFd</methodname></member>
  </simplelist>
 </refsect1>
</refentry>
