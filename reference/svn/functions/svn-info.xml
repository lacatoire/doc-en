<refentry xml:id="function.svn-info" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>svn_info</refname>
  <refpurpose>Returns information about a working copy or repository path</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type class="union"><type>array</type><type>false</type></type><methodname>svn_info</methodname>
   <methodparam><type>string</type><parameter>path</parameter></methodparam>
   <methodparam choice="opt"><type>bool</type><parameter>recurse</parameter><initializer>&true;</initializer></methodparam>
   <methodparam choice="opt"><type>int</type><parameter>revision</parameter><initializer>-1</initializer></methodparam>
  </methodsynopsis>
  <simpara>
   Returns information about <parameter>path</parameter>, which may be a
   working copy path or a URL.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>path</parameter></term>
    <listitem>
     <simpara>
      The path to query, either a working copy path or a URL.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>recurse</parameter></term>
    <listitem>
     <simpara>
      When &true;, information is gathered recursively for the children of
      a directory.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>revision</parameter></term>
    <listitem>
     <simpara>
      The revision number of the repository to query.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns an array of entries, each holding information such as the URL,
   revision number, node kind and last change details. On failure &false; is returned.
  </simpara>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>svn_status</function></member>
   <member><function>svn_log</function></member>
   <member><function>svn_ls</function></member>
  </simplelist>
 </refsect1>
</refentry>
