<refentry xml:id="function.svn-propget" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>svn_propget</refname>
  <refpurpose>Returns the value of a property for a path</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type class="union"><type>array</type><type>false</type></type><methodname>svn_propget</methodname>
   <methodparam><type>string</type><parameter>path</parameter></methodparam>
   <methodparam><type>string</type><parameter>property_name</parameter></methodparam>
   <methodparam choice="opt"><type>bool</type><parameter>recurse</parameter><initializer>&false;</initializer></methodparam>
   <methodparam choice="opt"><type>int</type><parameter>revision</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Retrieves the value of the property named <parameter>property_name</parameter>
   for <parameter>path</parameter> in a working copy or repository.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>path</parameter></term>
    <listitem>
     <simpara>
      Path to the working copy item or repository URL to inspect.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>property_name</parameter></term>
    <listitem>
     <simpara>
      Name of the property to retrieve.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>recurse</parameter></term>
    <listitem>
     <simpara>
      If &true;, descend recursively into any subdirectories of
      <parameter>path</parameter>.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>revision</parameter></term>
    <listitem>
     <simpara>
      The revision at which to retrieve the property. Defaults to the
      most recent revision.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns an array mapping each affected path to the value of the
   requested property. On failure &false; is returned.
  </simpara>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>svn_proplist</function></member>
   <member><function>svn_propset</function></member>
   <member><function>svn_prop_delete</function></member>
  </simplelist>
 </refsect1>
</refentry>
