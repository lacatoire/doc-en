<refentry xml:id="function.svn-switch" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>svn_switch</refname>
  <refpurpose>Update the working copy to a different URL</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type>bool</type><methodname>svn_switch</methodname>
   <methodparam><type>string</type><parameter>path</parameter></methodparam>
   <methodparam><type>string</type><parameter>url</parameter></methodparam>
   <methodparam choice="opt"><type>bool</type><parameter>working_copy</parameter><initializer>&true;</initializer></methodparam>
  </methodsynopsis>
  <simpara>
   Switches the working copy at <parameter>path</parameter> to point at the
   repository location given by <parameter>url</parameter>, updating the
   working copy to match.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>path</parameter></term>
    <listitem>
     <simpara>Path to the local working copy to switch.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>url</parameter></term>
    <listitem>
     <simpara>The repository URL to switch the working copy to.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>working_copy</parameter></term>
    <listitem>
     <simpara>
      When &true;, the current working revision is used; otherwise the
      operation is performed against the head revision.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns &true; on success. On failure &false; is returned.</simpara>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>svn_checkout</function></member>
   <member><function>svn_update</function></member>
  </simplelist>
 </refsect1>
</refentry>
