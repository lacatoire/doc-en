<refentry xml:id="function.svn-move" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>svn_move</refname>
  <refpurpose>Moves or renames a file or directory in a working copy or repository</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type class="union"><type>array</type><type>false</type></type><methodname>svn_move</methodname>
   <methodparam><type>string</type><parameter>src_path</parameter></methodparam>
   <methodparam><type>string</type><parameter>dst_path</parameter></methodparam>
   <methodparam choice="opt"><type>bool</type><parameter>force</parameter><initializer>&false;</initializer></methodparam>
  </methodsynopsis>
  <simpara>
   Moves <parameter>src_path</parameter> to <parameter>dst_path</parameter>
   in a working copy or a repository, effectively renaming the item.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>src_path</parameter></term>
    <listitem>
     <simpara>
      The source path to move, either a working copy path or a URL.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>dst_path</parameter></term>
    <listitem>
     <simpara>
      The destination path, either a working copy path or a URL.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>force</parameter></term>
    <listitem>
     <simpara>
      When &true;, the move is performed even if the source path has local
      modifications.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns an array holding the revision number, date and author of the
   resulting commit. On failure &false; is returned.
  </simpara>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>svn_copy</function></member>
   <member><function>svn_delete</function></member>
  </simplelist>
 </refsect1>
</refentry>
