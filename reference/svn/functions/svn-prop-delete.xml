<refentry xml:id="function.svn-prop-delete" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>svn_prop_delete</refname>
  <refpurpose>Deletes a property from a path</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type>bool</type><methodname>svn_prop_delete</methodname>
   <methodparam><type>string</type><parameter>path</parameter></methodparam>
   <methodparam><type>string</type><parameter>property_name</parameter></methodparam>
   <methodparam choice="opt"><type>bool</type><parameter>recurse</parameter><initializer>&false;</initializer></methodparam>
   <methodparam choice="opt"><type>bool</type><parameter>skip_checks</parameter><initializer>&false;</initializer></methodparam>
   <methodparam choice="opt"><type>int</type><parameter>revision</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Deletes the property named <parameter>property_name</parameter> from
   <parameter>path</parameter> in a working copy.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>path</parameter></term>
    <listitem>
     <simpara>
      Path to the working copy item from which to remove the property.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>property_name</parameter></term>
    <listitem>
     <simpara>
      Name of the property to delete.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>recurse</parameter></term>
    <listitem>
     <simpara>
      If &true;, descend recursively into any subdirectories of
      <parameter>path</parameter>.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>skip_checks</parameter></term>
    <listitem>
     <simpara>
      If &true;, skip the validity checks normally performed on some
      well-known properties.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>revision</parameter></term>
    <listitem>
     <simpara>
      The revision at which to operate. Defaults to the most recent
      revision.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success or &false; on failure.
  </simpara>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>svn_propset</function></member>
   <member><function>svn_propget</function></member>
   <member><function>svn_proplist</function></member>
  </simplelist>
 </refsect1>
</refentry>
