<refentry xml:id="function.svn-update2" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>svn_update2</refname>
  <refpurpose>Update working copy</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type class="union"><type>int</type><type>false</type></type><methodname>svn_update2</methodname>
   <methodparam><type>string</type><parameter>path</parameter></methodparam>
   <methodparam choice="opt"><type>int</type><parameter>revno</parameter><initializer><constant>SVN_REVISION_HEAD</constant></initializer></methodparam>
   <methodparam choice="opt"><type>int</type><parameter>flags</parameter><initializer>0</initializer></methodparam>
   <methodparam choice="opt"><type>int</type><parameter>depth</parameter><initializer>0</initializer></methodparam>
  </methodsynopsis>
  <simpara>
   Update the working copy at <parameter>path</parameter> to revision
   <parameter>revno</parameter>, bringing local changes down from the
   repository.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>path</parameter></term>
    <listitem>
     <simpara>Path to the local working copy to update.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>revno</parameter></term>
    <listitem>
     <simpara>
      The revision number to update to. Defaults to the head revision of
      the repository.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>flags</parameter></term>
    <listitem>
     <simpara>Any combination of update flags.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>depth</parameter></term>
    <listitem>
     <simpara>The depth to which the update is performed.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns the revision number of the updated working copy. On failure
   &false; is returned.
  </simpara>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>svn_update</function></member>
   <member><function>svn_checkout</function></member>
  </simplelist>
 </refsect1>
</refentry>
