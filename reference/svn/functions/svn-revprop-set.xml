<refentry xml:id="function.svn-revprop-set" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>svn_revprop_set</refname>
  <refpurpose>Sets the value of a revision property</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type class="union"><type>int</type><type>false</type></type><methodname>svn_revprop_set</methodname>
   <methodparam><type>string</type><parameter>url</parameter></methodparam>
   <methodparam><type>int</type><parameter>revision</parameter></methodparam>
   <methodparam><type>string</type><parameter>property_name</parameter></methodparam>
   <methodparam><type>string</type><parameter>property_value</parameter></methodparam>
   <methodparam choice="opt"><type>bool</type><parameter>force</parameter><initializer>&false;</initializer></methodparam>
  </methodsynopsis>
  <simpara>
   Sets the unversioned revision property named
   <parameter>property_name</parameter> to
   <parameter>property_value</parameter> for the given
   <parameter>revision</parameter> in the repository at
   <parameter>url</parameter>.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>url</parameter></term>
    <listitem>
     <simpara>
      URL pointing to the repository.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>revision</parameter></term>
    <listitem>
     <simpara>
      The revision whose property is changed.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>property_name</parameter></term>
    <listitem>
     <simpara>
      Name of the revision property to set.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>property_value</parameter></term>
    <listitem>
     <simpara>
      The value to assign to the revision property.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>force</parameter></term>
    <listitem>
     <simpara>
      If &true;, force the operation even when the repository would
      normally refuse to change the property.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns the revision number affected by the change. On failure
   &false; is returned.
  </simpara>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>svn_revprop_get</function></member>
   <member><function>svn_propset</function></member>
  </simplelist>
 </refsect1>
</refentry>
