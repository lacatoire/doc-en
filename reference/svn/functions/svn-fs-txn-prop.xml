<refentry xml:id="function.svn-fs-txn-prop" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>svn_fs_txn_prop</refname>
  <refpurpose>Return the value of a property on a transaction</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type class="union"><type>string</type><type>false</type></type><methodname>svn_fs_txn_prop</methodname>
   <methodparam><type>resource</type><parameter>txn</parameter></methodparam>
   <methodparam><type>string</type><parameter>propname</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Returns the value of the property named <parameter>propname</parameter> on
   the transaction <parameter>txn</parameter>.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>txn</parameter></term>
    <listitem>
     <simpara>A transaction resource, as returned by <function>svn_fs_open_txn</function>.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>propname</parameter></term>
    <listitem>
     <simpara>The name of the property to retrieve.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns the property value as a string, or an empty string if the property
   is not set. On failure &false; is returned.
  </simpara>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>svn_fs_open_txn</function></member>
   <member><function>svn_fs_change_node_prop</function></member>
   <member><function>svn_fs_node_prop</function></member>
  </simplelist>
 </refsect1>
</refentry>
