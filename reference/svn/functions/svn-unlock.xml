<refentry xml:id="function.svn-unlock" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>svn_unlock</refname>
  <refpurpose>Unlocks one or more paths in the repository</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type>bool</type><methodname>svn_unlock</methodname>
   <methodparam><type>mixed</type><parameter>targets</parameter></methodparam>
   <methodparam choice="opt"><type>bool</type><parameter>break_lock</parameter><initializer>&false;</initializer></methodparam>
  </methodsynopsis>
  <simpara>
   Removes the locks on the given <parameter>targets</parameter> in the
   repository.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>targets</parameter></term>
    <listitem>
     <simpara>
      A single path as a string, or an array of paths, to unlock.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>break_lock</parameter></term>
    <listitem>
     <simpara>
      When &true;, a lock held by another user is broken.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success or &false; on failure.
  </simpara>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>svn_lock</function></member>
  </simplelist>
 </refsect1>
</refentry>
