<refentry xml:id="function.svn-revprop-delete" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>svn_revprop_delete</refname>
  <refpurpose>Deletes an unversioned revision property</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type class="union"><type>int</type><type>false</type></type><methodname>svn_revprop_delete</methodname>
   <methodparam><type>string</type><parameter>url</parameter></methodparam>
   <methodparam><type>int</type><parameter>revision</parameter></methodparam>
   <methodparam><type>string</type><parameter>property_name</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Deletes the unversioned revision property <parameter>property_name</parameter>
   from the revision <parameter>revision</parameter> of the repository
   identified by <parameter>url</parameter>.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>url</parameter></term>
    <listitem>
     <simpara>
      URL that references a repository, for example
      <literal>svn://svn.example.com/repos/project</literal>.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>revision</parameter></term>
    <listitem>
     <simpara>
      The revision number of the revision to delete the property from.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>property_name</parameter></term>
    <listitem>
     <simpara>
      Name of the revision property to delete.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns the revision number of the affected revision. On failure &false; is returned.
  </simpara>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>svn_revprop_get</function></member>
   <member><function>svn_revprop_set</function></member>
  </simplelist>
 </refsect1>
</refentry>
