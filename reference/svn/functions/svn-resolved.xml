<refentry xml:id="function.svn-resolved" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>svn_resolved</refname>
  <refpurpose>Resolve a conflicted item in a working copy</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type>bool</type><methodname>svn_resolved</methodname>
   <methodparam><type>string</type><parameter>path</parameter></methodparam>
   <methodparam choice="opt"><type>bool</type><parameter>recursive</parameter><initializer>&false;</initializer></methodparam>
  </methodsynopsis>
  <simpara>
   Removes the conflicted state on a working copy item at
   <parameter>path</parameter>, marking the conflict as resolved. This does
   not resolve the conflict itself; it merely tells Subversion that the
   conflict has been dealt with.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>path</parameter></term>
    <listitem>
     <simpara>The path to the conflicted working copy item.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>recursive</parameter></term>
    <listitem>
     <simpara>
      When &true; and <parameter>path</parameter> is a directory, the
      conflicted state is cleared recursively on its children.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns &true; on success. On failure &false; is returned.</simpara>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>svn_update</function></member>
   <member><function>svn_status</function></member>
  </simplelist>
 </refsect1>
</refentry>
