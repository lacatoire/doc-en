<refentry xml:id="gmagickdraw.setclippath" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>GmagickDraw::setclippath</refname>
  <refpurpose>Associates a named clipping path with the drawing context</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>GmagickDraw</type><methodname>GmagickDraw::setclippath</methodname>
   <methodparam><type>string</type><parameter>clip_mask</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Associates a named clipping path with the <classname>GmagickDraw</classname> object. Subsequent drawing operations are restricted to the interior of the referenced clip path.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>clip_mask</parameter></term>
    <listitem>
     <simpara>
      The name of the clip path to associate with the drawing context.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>The <classname>GmagickDraw</classname> object.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws a <exceptionname>GmagickDrawException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
