<refentry xml:id="gmagickdraw.settextundercolor" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>GmagickDraw::settextundercolor</refname>
  <refpurpose>Sets the color of the background rectangle drawn under text</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>GmagickDraw</type><methodname>GmagickDraw::settextundercolor</methodname>
   <methodparam><type class="union"><type>GmagickPixel</type><type>string</type></type><parameter>color</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Specifies the color of a background rectangle to place under text
   annotations.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>color</parameter></term>
    <listitem>
     <simpara>
      A <classname>GmagickPixel</classname> object or a string indicating the
      text under color.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>The GmagickDraw object.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws a <exceptionname>GmagickDrawException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
