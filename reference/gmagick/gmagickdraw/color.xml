<refentry xml:id="gmagickdraw.color" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>GmagickDraw::color</refname>
  <refpurpose>Draws color on the image using the current fill color</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>GmagickDraw</type><methodname>GmagickDraw::color</methodname>
   <methodparam><type>float</type><parameter>x</parameter></methodparam>
   <methodparam><type>float</type><parameter>y</parameter></methodparam>
   <methodparam><type>int</type><parameter>paint_method</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Draws color on the image using the current fill color, starting at the specified coordinate and spreading according to the given paint method.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>x</parameter></term>
    <listitem>
     <simpara>
      The x coordinate of the starting point.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>y</parameter></term>
    <listitem>
     <simpara>
      The y coordinate of the starting point.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>paint_method</parameter></term>
    <listitem>
     <simpara>
      The paint method, one of the <constant>Gmagick::PAINT_*</constant> constants, which controls how far the color is spread from the starting coordinate.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>The <classname>GmagickDraw</classname> object.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws a <exceptionname>GmagickDrawException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
