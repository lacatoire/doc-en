<refentry xml:id="gmagickdraw.pathellipticarcabsolute" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>GmagickDraw::pathellipticarcabsolute</refname>
  <refpurpose>Draws an elliptical arc</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>GmagickDraw</type><methodname>GmagickDraw::pathellipticarcabsolute</methodname>
   <methodparam><type>float</type><parameter>rx</parameter></methodparam>
   <methodparam><type>float</type><parameter>ry</parameter></methodparam>
   <methodparam><type>float</type><parameter>x_axis_rotation</parameter></methodparam>
   <methodparam><type>bool</type><parameter>large_arc_flag</parameter></methodparam>
   <methodparam><type>bool</type><parameter>sweep_flag</parameter></methodparam>
   <methodparam><type>float</type><parameter>x</parameter></methodparam>
   <methodparam><type>float</type><parameter>y</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Draws an elliptical arc, using absolute coordinates, from the current point to the coordinate given by (<parameter>x</parameter>, <parameter>y</parameter>). The size and orientation of the ellipse are defined by the two radii (<parameter>rx</parameter>, <parameter>ry</parameter>) and an <parameter>x_axis_rotation</parameter>, which indicates how the ellipse as a whole is rotated relative to the current coordinate system. The <parameter>large_arc_flag</parameter> and <parameter>sweep_flag</parameter> contribute to the automatic calculations and help determine how the arc is drawn.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>rx</parameter></term>
    <listitem>
     <simpara>
      The x radius of the ellipse.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>ry</parameter></term>
    <listitem>
     <simpara>
      The y radius of the ellipse.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>x_axis_rotation</parameter></term>
    <listitem>
     <simpara>
      The rotation of the ellipse, in degrees, relative to the current coordinate system.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>large_arc_flag</parameter></term>
    <listitem>
     <simpara>
      If &true;, the larger of the two possible arcs is drawn.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>sweep_flag</parameter></term>
    <listitem>
     <simpara>
      If &true;, the arc is drawn in the positive-angle (clockwise) direction.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>x</parameter></term>
    <listitem>
     <simpara>
      The x coordinate of the end of the arc.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>y</parameter></term>
    <listitem>
     <simpara>
      The y coordinate of the end of the arc.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>The <classname>GmagickDraw</classname> object.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws a <exceptionname>GmagickDrawException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
