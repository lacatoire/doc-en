<refentry xml:id="gmagickdraw.pathstart" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>GmagickDraw::pathstart</refname>
  <refpurpose>Declares the start of a path drawing list</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>GmagickDraw</type><methodname>GmagickDraw::pathstart</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Declares the start of a path drawing list which is terminated by a matching <function>GmagickDraw::pathfinish</function> command. All other path drawing commands must be enclosed between a <function>GmagickDraw::pathstart</function> and a <function>GmagickDraw::pathfinish</function> command. This is because path drawing commands are subordinate commands and they cannot be directly rendered.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>The <classname>GmagickDraw</classname> object.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws a <exceptionname>GmagickDrawException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
