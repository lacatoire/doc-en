<refentry xml:id="gmagickdraw.comment" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>GmagickDraw::comment</refname>
  <refpurpose>Adds a comment to the vector output stream</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>GmagickDraw</type><methodname>GmagickDraw::comment</methodname>
   <methodparam><type>string</type><parameter>comment</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Adds a comment to the vector output stream describing the drawing operations.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>comment</parameter></term>
    <listitem>
     <simpara>
      The comment string to add to the vector output stream.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>The <classname>GmagickDraw</classname> object.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws a <exceptionname>GmagickDrawException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
