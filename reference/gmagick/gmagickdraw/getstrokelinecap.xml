<refentry xml:id="gmagickdraw.getstrokelinecap" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>GmagickDraw::getstrokelinecap</refname>
  <refpurpose>Returns the shape used at the end of open subpaths when stroked</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>int</type><methodname>GmagickDraw::getstrokelinecap</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Returns the shape to be used at the end of open subpaths when they are stroked, as one of the <constant>Gmagick::LINECAP_*</constant> constants.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the line cap as one of the <constant>Gmagick::LINECAP_*</constant> constants.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws a <exceptionname>GmagickDrawException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
