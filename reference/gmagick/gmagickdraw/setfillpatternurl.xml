<refentry xml:id="gmagickdraw.setfillpatternurl" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>GmagickDraw::setfillpatternurl</refname>
  <refpurpose>Sets the URL to use as a fill pattern for filling objects</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>GmagickDraw</type><methodname>GmagickDraw::setfillpatternurl</methodname>
   <methodparam><type>string</type><parameter>fill_url</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Sets the URL to use as a fill pattern for filling objects. Only local URLs ("#identifier") are supported at this time; the referenced pattern must have been previously defined.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>fill_url</parameter></term>
    <listitem>
     <simpara>
      The fill pattern URL. Only local URLs, in the form "#identifier" referencing a previously defined pattern, are supported.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>The <classname>GmagickDraw</classname> object.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws a <exceptionname>GmagickDrawException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
