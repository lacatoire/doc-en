<refentry xml:id="gmagickdraw.setfontstretch" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>GmagickDraw::setfontstretch</refname>
  <refpurpose>Sets the font stretch to use when annotating with text</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>GmagickDraw::setfontstretch</methodname>
   <methodparam><type>int</type><parameter>font_stretch</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Sets the font stretch to use when annotating with text. The <constant>Gmagick::STRETCH_ANY</constant> value resets the stretch to its default state.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>font_stretch</parameter></term>
    <listitem>
     <simpara>
      The font stretch, one of the <constant>Gmagick::STRETCH_*</constant> constants (for example <constant>Gmagick::STRETCH_NORMAL</constant> or <constant>Gmagick::STRETCH_CONDENSED</constant>).
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns &true; on success.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws a <exceptionname>GmagickDrawException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
