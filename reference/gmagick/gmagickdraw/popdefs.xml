<refentry xml:id="gmagickdraw.popdefs" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>GmagickDraw::popdefs</refname>
  <refpurpose>Terminates a definition list</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>GmagickDraw</type><methodname>GmagickDraw::popdefs</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Terminates a definition list started by a matching <function>GmagickDraw::pushdefs</function> command.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>The <classname>GmagickDraw</classname> object.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws a <exceptionname>GmagickDrawException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
