<refentry xml:id="gmagickdraw.pushclippath" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>GmagickDraw::pushclippath</refname>
  <refpurpose>Starts a clip path definition</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>GmagickDraw</type><methodname>GmagickDraw::pushclippath</methodname>
   <methodparam><type>string</type><parameter>clip_mask_id</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Starts a clip path definition which is comprised of the drawing commands
   issued until a matching pop operation. The path is registered under the
   given identifier so it can later be selected as the active clipping mask.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>clip_mask_id</parameter></term>
    <listitem>
     <simpara>The clip path identification for later reference.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>The GmagickDraw object.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws a <exceptionname>GmagickDrawException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
