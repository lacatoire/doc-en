<refentry xml:id="gmagickdraw.setstrokelinejoin" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>GmagickDraw::setstrokelinejoin</refname>
  <refpurpose>Sets the shape used at the corners of paths when stroked</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>GmagickDraw</type><methodname>GmagickDraw::setstrokelinejoin</methodname>
   <methodparam><type>int</type><parameter>linejoin</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Specifies the shape to be used at the corners of paths (or other vector shapes) when they are stroked.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>linejoin</parameter></term>
    <listitem>
     <simpara>
      The line join, given as one of the <constant>Gmagick::LINEJOIN_*</constant> constants.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>The <classname>GmagickDraw</classname> object.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws a <exceptionname>GmagickDrawException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
