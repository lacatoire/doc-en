<refentry xml:id="gmagickdraw.skewy" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>GmagickDraw::skewy</refname>
  <refpurpose>Skews the current coordinate system in the vertical direction</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>GmagickDraw</type><methodname>GmagickDraw::skewy</methodname>
   <methodparam><type>float</type><parameter>degrees</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Skews the current coordinate system in the vertical direction by the given
   angle. Subsequent drawing operations are affected by the applied
   transformation.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>degrees</parameter></term>
    <listitem>
     <simpara>The skew angle, in degrees.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>The GmagickDraw object.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws a <exceptionname>GmagickDrawException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
