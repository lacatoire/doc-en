<refentry xml:id="gmagick.clippathimage" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::clippathimage</refname>
  <refpurpose>Clips along a named path from the 8BIM profile</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>Gmagick::clippathimage</methodname>
   <methodparam><type>string</type><parameter>pathname</parameter></methodparam>
   <methodparam><type>bool</type><parameter>inside</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Clips along the named path found in the image's 8BIM profile, if present, restricting subsequent operations to the selected region.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>pathname</parameter></term>
    <listitem>
     <simpara>
      The name of the clipping path stored in the 8BIM profile.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>inside</parameter></term>
    <listitem>
     <simpara>
      If &true;, pixels inside the path are retained; if &false;, pixels outside the path are retained instead.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
