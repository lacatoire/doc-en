<refentry xml:id="gmagick.compareimages" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::compareimages</refname>
  <refpurpose>Compares two images and returns the difference</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>array</type><methodname>Gmagick::compareimages</methodname>
   <methodparam><type>Gmagick</type><parameter>reference</parameter></methodparam>
   <methodparam><type>int</type><parameter>metric</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Compares the image with a reference image and quantifies their difference
   using the given metric.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>reference</parameter></term>
    <listitem>
     <simpara>
      The reference <classname>Gmagick</classname> image to compare against.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>metric</parameter></term>
    <listitem>
     <simpara>
      The metric used to compute the difference, given as one of the
      <constant>Gmagick::METRIC_*</constant> constants.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns an array whose first element is a new
   <classname>Gmagick</classname> object holding the difference image and whose
   second element is the computed distortion.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
