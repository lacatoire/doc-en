<refentry xml:id="gmagick.setimage" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::setimage</refname>
  <refpurpose>Replaces the current image in the sequence</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>Gmagick::setimage</methodname>
   <methodparam><type>Gmagick</type><parameter>replace</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Replaces the image at the current iterator position with a copy of the image held by the given Gmagick object.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>replace</parameter></term>
    <listitem>
     <simpara>
      The Gmagick object whose current image is used as the replacement.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
