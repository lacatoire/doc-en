<refentry xml:id="gmagick.getimagefuzz" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::getimagefuzz</refname>
  <refpurpose>Gets the image fuzz</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>float</type><methodname>Gmagick::getimagefuzz</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Returns the color comparison fuzz factor currently set on the image. Colors
   that differ by no more than this amount are treated as equal during color
   comparisons.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the fuzz value as a float.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
