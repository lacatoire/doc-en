<refentry xml:id="gmagick.steganoimage" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::steganoimage</refname>
  <refpurpose>Hides a digital watermark within the image</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Gmagick</type><methodname>Gmagick::steganoimage</methodname>
   <methodparam><type>Gmagick</type><parameter>watermark_wand</parameter></methodparam>
   <methodparam><type>int</type><parameter>offset</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Hides a digital watermark within the image using steganography, embedding
   the watermark image starting at the given pixel offset. The watermark can
   later be recovered from the returned image. The result is returned as a new
   <classname>Gmagick</classname> object.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>watermark_wand</parameter></term>
    <listitem>
     <simpara>
      The <classname>Gmagick</classname> object holding the watermark image to
      embed.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>offset</parameter></term>
    <listitem>
     <simpara>
      The starting pixel offset at which the watermark is embedded.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>The <classname>Gmagick</classname> object.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
