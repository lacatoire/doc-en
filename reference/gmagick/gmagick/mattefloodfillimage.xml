<refentry xml:id="gmagick.mattefloodfillimage" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::mattefloodfillimage</refname>
  <refpurpose>Changes the transparency of connected pixels by flood fill</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>Gmagick::mattefloodfillimage</methodname>
   <methodparam><type>float</type><parameter>alpha</parameter></methodparam>
   <methodparam><type>float</type><parameter>fuzz</parameter></methodparam>
   <methodparam><type>GmagickPixel</type><parameter>bordercolor</parameter></methodparam>
   <methodparam><type>int</type><parameter>x</parameter></methodparam>
   <methodparam><type>int</type><parameter>y</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Sets the transparency (matte) value of the pixel at the given coordinate and
   of all its neighbouring pixels that match its color, flood filling outward
   until pixels matching the border color, or the edge of the image, are
   reached.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>alpha</parameter></term>
    <listitem>
     <simpara>
      The level of transparency to apply, expressed as a matte value.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>fuzz</parameter></term>
    <listitem>
     <simpara>
      The color-matching tolerance; colors within this distance of the target
      color are treated as equal.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>bordercolor</parameter></term>
    <listitem>
     <simpara>
      The color that bounds the flood fill; filling stops when this color is
      encountered.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>x</parameter></term>
    <listitem>
     <simpara>
      The x coordinate of the pixel at which the flood fill starts.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>y</parameter></term>
    <listitem>
     <simpara>
      The y coordinate of the pixel at which the flood fill starts.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns &true; on success.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
