<refentry xml:id="gmagick.unsharpmaskimage" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::unsharpmaskimage</refname>
  <refpurpose>Sharpens the image using an unsharp mask</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Gmagick</type><methodname>Gmagick::unsharpmaskimage</methodname>
   <methodparam><type>float</type><parameter>radius</parameter></methodparam>
   <methodparam><type>float</type><parameter>sigma</parameter></methodparam>
   <methodparam><type>float</type><parameter>amount</parameter></methodparam>
   <methodparam><type>float</type><parameter>threshold</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Sharpens the image using an unsharp mask, which enhances edges by subtracting
   a blurred (Gaussian) copy of the image from the original.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>radius</parameter></term>
    <listitem>
     <simpara>
      The radius of the Gaussian, in pixels, not counting the center pixel. A
      value of <literal>0</literal> lets the method select a suitable radius.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>sigma</parameter></term>
    <listitem>
     <simpara>
      The standard deviation of the Gaussian, in pixels.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>amount</parameter></term>
    <listitem>
     <simpara>
      The fraction of the difference between the original and the blurred image
      that is added back into the original.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>threshold</parameter></term>
    <listitem>
     <simpara>
      The threshold, as a fraction of the quantum range, below which local
      differences are considered noise and left unsharpened.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   The sharpened <classname>Gmagick</classname> object.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
