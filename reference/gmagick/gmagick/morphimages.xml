<refentry xml:id="gmagick.morphimages" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::morphimages</refname>
  <refpurpose>Morphs a set of images</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Gmagick</type><methodname>Gmagick::morphimages</methodname>
   <methodparam><type>int</type><parameter>frames</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Morphs the sequence of images held in the object, blending each image into
   the next by inserting a number of intermediate images between every pair.
   This produces a smooth transition suitable for animation. The morphed
   sequence is returned as a new <classname>Gmagick</classname> object.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>frames</parameter></term>
    <listitem>
     <simpara>
      The number of intermediate images to insert between each pair of images
      in the sequence.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>The <classname>Gmagick</classname> object.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
