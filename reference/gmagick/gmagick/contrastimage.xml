<refentry xml:id="gmagick.contrastimage" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::contrastimage</refname>
  <refpurpose>Enhances the contrast of the image</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>Gmagick::contrastimage</methodname>
   <methodparam><type>bool</type><parameter>sharpen</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Enhances the intensity differences between the lighter and darker elements of
   the image. When <parameter>sharpen</parameter> is &true; the contrast is
   increased, otherwise it is reduced.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>sharpen</parameter></term>
    <listitem>
     <simpara>
      Whether to increase (&true;) or reduce (&false;) the image contrast.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns &true; on success.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
