<refentry xml:id="gmagick.montageimage" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::montageimage</refname>
  <refpurpose>Creates a composite image from a set of images</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Gmagick</type><methodname>Gmagick::montageimage</methodname>
   <methodparam><type>GmagickDraw</type><parameter>drawing_wand</parameter></methodparam>
   <methodparam><type>string</type><parameter>tile_geometry</parameter></methodparam>
   <methodparam><type>string</type><parameter>thumbnail_geometry</parameter></methodparam>
   <methodparam><type>int</type><parameter>mode</parameter></methodparam>
   <methodparam><type>string</type><parameter>frame</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Creates a composite image by arranging the images held in the object into a
   tiled montage, optionally labelling and framing each tile. The result is
   returned as a new <classname>Gmagick</classname> object.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>drawing_wand</parameter></term>
    <listitem>
     <simpara>
      A <classname>GmagickDraw</classname> object providing the font and color
      settings used to render the tile labels.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>tile_geometry</parameter></term>
    <listitem>
     <simpara>
      The number of tiles per row and column, as a geometry string such as
      <literal>"4x3"</literal>.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>thumbnail_geometry</parameter></term>
    <listitem>
     <simpara>
      The size and spacing of each thumbnail tile, given as a geometry string.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>mode</parameter></term>
    <listitem>
     <simpara>
      The montage mode, one of the
      <constant>Gmagick::MONTAGEMODE_*</constant> constants.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>frame</parameter></term>
    <listitem>
     <simpara>
      The frame ornament drawn around each tile, as a geometry string; an empty
      string disables the frame.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>The <classname>Gmagick</classname> object.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
