<refentry xml:id="gmagick.colorfloodfillimage" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::colorfloodfillimage</refname>
  <refpurpose>Fills a bounded region of the image with a color</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>Gmagick::colorfloodfillimage</methodname>
   <methodparam><type>mixed</type><parameter>fill</parameter></methodparam>
   <methodparam><type>float</type><parameter>fuzz</parameter></methodparam>
   <methodparam><type class="union"><type>GmagickPixel</type><type>string</type></type><parameter>bordercolor</parameter></methodparam>
   <methodparam><type>int</type><parameter>x</parameter></methodparam>
   <methodparam><type>int</type><parameter>y</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Paints, starting at the given coordinate, the pixels of the image with the
   fill color until the pixels matching the border color are reached. The fuzz
   value controls how closely a pixel must match the border color for the fill
   to stop.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>fill</parameter></term>
    <listitem>
     <simpara>
      The fill color, as a <classname>GmagickPixel</classname> object or a color string.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>fuzz</parameter></term>
    <listitem>
     <simpara>
      The fuzz factor; colors within this distance are considered equal. Larger
      values match a broader range of colors.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>bordercolor</parameter></term>
    <listitem>
     <simpara>
      The border color that bounds the region to be filled, as a
      <classname>GmagickPixel</classname> object or a color string.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>x</parameter></term>
    <listitem>
     <simpara>
      The x offset of the pixel where the fill starts.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>y</parameter></term>
    <listitem>
     <simpara>
      The y offset of the pixel where the fill starts.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns &true; on success.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
