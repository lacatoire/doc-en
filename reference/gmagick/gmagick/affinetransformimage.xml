<refentry xml:id="gmagick.affinetransformimage" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::affinetransformimage</refname>
  <refpurpose>Transforms the image with an affine matrix</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>Gmagick::affinetransformimage</methodname>
   <methodparam><type>GmagickDraw</type><parameter>drawing_wand</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Applies an affine transformation, combining scaling, rotation, translation
   and shearing, to the image using the transformation matrix defined in the
   given <classname>GmagickDraw</classname> object.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>drawing_wand</parameter></term>
    <listitem>
     <simpara>
      The <classname>GmagickDraw</classname> object that defines the affine
      transformation matrix.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
