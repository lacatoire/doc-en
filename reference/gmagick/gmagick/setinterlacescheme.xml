<refentry xml:id="gmagick.setinterlacescheme" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::setinterlacescheme</refname>
  <refpurpose>Sets the image interlace scheme</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Gmagick</type><methodname>Gmagick::setinterlacescheme</methodname>
   <methodparam><type>int</type><parameter>interlace_scheme</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Sets the interlace scheme used when the image is written, controlling how the image data is ordered, for example progressive (interlaced) or non-interlaced output.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>interlace_scheme</parameter></term>
    <listitem>
     <simpara>
      One of the <literal>Gmagick::INTERLACE_*</literal> constants.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   The Gmagick object.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
