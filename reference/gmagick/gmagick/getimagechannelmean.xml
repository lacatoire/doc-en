<refentry xml:id="gmagick.getimagechannelmean" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::getimagechannelmean</refname>
  <refpurpose>Gets the mean of an image channel</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>array</type><methodname>Gmagick::getimagechannelmean</methodname>
   <methodparam><type>int</type><parameter>channel</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Gets the mean and standard deviation of the pixel values for the specified
   image channel.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>channel</parameter></term>
    <listitem>
     <simpara>
      The channel to inspect, given as one of the
      <constant>Gmagick::CHANNEL_*</constant> constants.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns an array with the keys <literal>mean</literal> and
   <literal>standardDeviation</literal> describing the pixel value distribution of
   the channel.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
