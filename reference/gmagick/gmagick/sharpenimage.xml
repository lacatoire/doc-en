<refentry xml:id="gmagick.sharpenimage" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::sharpenimage</refname>
  <refpurpose>Sharpens the image</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>Gmagick::sharpenimage</methodname>
   <methodparam><type>float</type><parameter>radius</parameter></methodparam>
   <methodparam><type>float</type><parameter>sigma</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Sharpens the image by convolving it with a Gaussian operator of the given
   radius and standard deviation (sigma).
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>radius</parameter></term>
    <listitem>
     <simpara>
      The radius of the Gaussian, in pixels, not counting the center pixel. A
      value of <literal>0</literal> lets the method select a suitable radius.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>sigma</parameter></term>
    <listitem>
     <simpara>
      The standard deviation of the Gaussian, in pixels.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
