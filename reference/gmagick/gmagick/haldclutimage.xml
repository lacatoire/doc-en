<refentry xml:id="gmagick.haldclutimage" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::haldclutimage</refname>
  <refpurpose>Applies a Hald color lookup table to the image</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>Gmagick::haldclutimage</methodname>
   <methodparam><type>Gmagick</type><parameter>hald</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Applies a Hald color lookup table (CLUT) to the image. The Hald image
   encodes a three-dimensional color transformation; every pixel of the image
   is replaced by the color found by looking up its original color in the Hald
   CLUT, which allows arbitrary color corrections to be applied at once.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>hald</parameter></term>
    <listitem>
     <simpara>
      The <classname>Gmagick</classname> object holding the Hald CLUT image.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns &true; on success.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
