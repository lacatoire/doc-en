<refentry xml:id="gmagick.thresholdimage" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::thresholdimage</refname>
  <refpurpose>Applies a threshold to the image</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>Gmagick::thresholdimage</methodname>
   <methodparam><type>float</type><parameter>threshold</parameter></methodparam>
   <methodparam choice="opt"><type>int</type><parameter>channel</parameter><initializer><constant>Gmagick::CHANNEL_DEFAULT</constant></initializer></methodparam>
  </methodsynopsis>
  <simpara>
   Changes the value of individual pixels based on the intensity of each pixel compared to the given threshold. Pixels at or above the threshold are set to white, and pixels below it are set to black, producing a bilevel result.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>threshold</parameter></term>
    <listitem>
     <simpara>
      The threshold value, expressed in the range of the image's quantum values.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>channel</parameter></term>
    <listitem>
     <simpara>
      The channel the threshold is applied to. Refer to the list of <link linkend="gmagick.constants.channel">channel constants</link>.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
