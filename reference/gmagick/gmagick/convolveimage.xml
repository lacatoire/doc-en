<refentry xml:id="gmagick.convolveimage" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::convolveimage</refname>
  <refpurpose>Applies a convolution kernel to the image</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>Gmagick::convolveimage</methodname>
   <methodparam><type>array</type><parameter>kernel</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Applies a user-supplied convolution kernel to the image, computing each output
   pixel as the weighted sum of its neighbouring pixels.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>kernel</parameter></term>
    <listitem>
     <simpara>
      The convolution kernel as an array of floats. It must contain an odd,
      perfect-square number of values describing a square matrix in row-major
      order.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns &true; on success.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
