<refentry xml:id="gmagick.setresolution" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::setresolution</refname>
  <refpurpose>Sets the image resolution</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>Gmagick::setresolution</methodname>
   <methodparam><type>float</type><parameter>x_resolution</parameter></methodparam>
   <methodparam><type>float</type><parameter>y_resolution</parameter></methodparam>
   <methodparam><type>float</type><parameter>amount</parameter></methodparam>
   <methodparam><type>float</type><parameter>threshold</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Sets the horizontal and vertical resolution of the image, expressed in the
   current resolution units.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>x_resolution</parameter></term>
    <listitem>
     <simpara>
      The horizontal resolution, in the current resolution units.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>y_resolution</parameter></term>
    <listitem>
     <simpara>
      The vertical resolution, in the current resolution units.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>amount</parameter></term>
    <listitem>
     <simpara>
      Additional resolution adjustment applied to the image.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>threshold</parameter></term>
    <listitem>
     <simpara>
      Threshold value controlling the resolution change.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
