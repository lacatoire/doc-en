<refentry xml:id="gmagick.setimagevirtualpixelmethod" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::setimagevirtualpixelmethod</refname>
  <refpurpose>Sets the image virtual pixel method</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>Gmagick::setimagevirtualpixelmethod</methodname>
   <methodparam><type>int</type><parameter>method</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Sets the image virtual pixel method, which determines how pixels that lie
   outside the boundaries of the image are resolved when they are accessed by
   operations such as convolution, resampling or distortion.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>method</parameter></term>
    <listitem>
     <simpara>
      The virtual pixel method, one of the
      <constant>Gmagick::VIRTUALPIXELMETHOD_*</constant> constants.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns &true; on success.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
