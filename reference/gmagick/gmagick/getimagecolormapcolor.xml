<refentry xml:id="gmagick.getimagecolormapcolor" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::getimagecolormapcolor</refname>
  <refpurpose>Returns a color from the image colormap</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>GmagickPixel</type><methodname>Gmagick::getimagecolormapcolor</methodname>
   <methodparam><type>int</type><parameter>index</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Returns the color stored at the given index of the image colormap, used by
   palette (indexed) images.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>index</parameter></term>
    <listitem>
     <simpara>
      The position in the colormap whose color is retrieved.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns a <classname>GmagickPixel</classname> object holding the color at the
   given colormap index.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
