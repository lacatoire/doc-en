<refentry xml:id="gmagick.transformimage" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::transformimage</refname>
  <refpurpose>Crops and resizes the image</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Gmagick</type><methodname>Gmagick::transformimage</methodname>
   <methodparam><type>string</type><parameter>crop</parameter></methodparam>
   <methodparam><type>string</type><parameter>geometry</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Returns a transformed copy of the image: the image is first cropped to the
   region given by the crop geometry and then resized to the size given by the
   geometry. The transformed image is returned as a new
   <classname>Gmagick</classname> object.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>crop</parameter></term>
    <listitem>
     <simpara>
      A crop geometry string defining the region to keep, such as
      <literal>"100x100+10+20"</literal>.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>geometry</parameter></term>
    <listitem>
     <simpara>
      An image geometry string defining the size of the resulting image, such
      as <literal>"200x200"</literal>.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>The <classname>Gmagick</classname> object.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
