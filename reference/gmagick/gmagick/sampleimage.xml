<refentry xml:id="gmagick.sampleimage" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::sampleimage</refname>
  <refpurpose>Scales an image using pixel sampling</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Gmagick</type><methodname>Gmagick::sampleimage</methodname>
   <methodparam><type>int</type><parameter>cols</parameter></methodparam>
   <methodparam><type>int</type><parameter>rows</parameter></methodparam>
   <methodparam choice="opt"><type>bool</type><parameter>fit</parameter><initializer>&false;</initializer></methodparam>
   <methodparam choice="opt"><type>bool</type><parameter>legacy</parameter><initializer>&false;</initializer></methodparam>
  </methodsynopsis>
  <simpara>
   Resizes the image to the given dimensions by directly sampling pixels,
   without interpolation or color averaging. This is faster than resizing but
   produces coarser results.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>cols</parameter></term>
    <listitem>
     <simpara>
      The number of columns (width) of the resulting image.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>rows</parameter></term>
    <listitem>
     <simpara>
      The number of rows (height) of the resulting image.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>fit</parameter></term>
    <listitem>
     <simpara>
      Whether to preserve the aspect ratio so the image fits within the
      requested dimensions.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>legacy</parameter></term>
    <listitem>
     <simpara>
      Whether to use the legacy sampling behavior for backward compatibility.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   The sampled <classname>Gmagick</classname> object.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
