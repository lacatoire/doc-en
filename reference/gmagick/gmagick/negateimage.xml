<refentry xml:id="gmagick.negateimage" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::negateimage</refname>
  <refpurpose>Negates the colors of the image</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>Gmagick::negateimage</methodname>
   <methodparam><type>bool</type><parameter>gray</parameter></methodparam>
   <methodparam choice="opt"><type>int</type><parameter>channel</parameter><initializer><constant>Gmagick::CHANNEL_DEFAULT</constant></initializer></methodparam>
  </methodsynopsis>
  <simpara>
   Negates the colors in the image, producing the equivalent of a photographic
   negative. The operation can be restricted to specific color channels.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>gray</parameter></term>
    <listitem>
     <simpara>
      If &true;, only the grayscale values are negated, leaving the color
      information unchanged.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>channel</parameter></term>
    <listitem>
     <simpara>
      The channel or channels to negate, given as a channel type constant.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
