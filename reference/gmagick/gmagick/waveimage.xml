<refentry xml:id="gmagick.waveimage" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::waveimage</refname>
  <refpurpose>Applies a wave filter to the image</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>Gmagick::waveimage</methodname>
   <methodparam><type>float</type><parameter>amplitude</parameter></methodparam>
   <methodparam><type>float</type><parameter>length</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Applies a wave filter to the image, creating a ripple effect by displacing
   pixels along a sine wave defined by the given amplitude and wavelength.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>amplitude</parameter></term>
    <listitem>
     <simpara>
      The amplitude of the wave, that is the maximum distance by which pixels
      are displaced.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>length</parameter></term>
    <listitem>
     <simpara>
      The wavelength of the wave.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns &true; on success.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
