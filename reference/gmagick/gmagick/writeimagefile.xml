<refentry xml:id="gmagick.writeimagefile" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::writeimagefile</refname>
  <refpurpose>Writes an image to an open filehandle</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>Gmagick</type><methodname>Gmagick::writeimagefile</methodname>
   <methodparam><type>resource</type><parameter>filehandle</parameter></methodparam>
   <methodparam choice="opt"><type class="union"><type>string</type><type>null</type></type><parameter>format</parameter><initializer>&null;</initializer></methodparam>
  </methodsynopsis>
  <simpara>
   Writes the current image to an already opened file resource.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>filehandle</parameter></term>
    <listitem>
     <simpara>
      An open filehandle resource the image data is written to.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>format</parameter></term>
    <listitem>
     <simpara>
      Optional image format the data should be encoded in, such as <literal>PNG</literal> or <literal>JPEG</literal>. If omitted, the image's current format is used.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   The Gmagick object.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
