<refentry xml:id="gmagick.shaveimage" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::shaveimage</refname>
  <refpurpose>Shaves pixels from the image edges</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>Gmagick::shaveimage</methodname>
   <methodparam><type>int</type><parameter>columns</parameter></methodparam>
   <methodparam><type>int</type><parameter>rows</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Shaves pixels from the edges of the image, removing the given number of
   columns from the left and right sides and the given number of rows from the
   top and bottom, reducing the image size accordingly.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>columns</parameter></term>
    <listitem>
     <simpara>
      The number of columns to remove from the left and right edges.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>rows</parameter></term>
    <listitem>
     <simpara>
      The number of rows to remove from the top and bottom edges.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns &true; on success.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
