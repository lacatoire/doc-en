<refentry xml:id="gmagick.colorizeimage" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Gmagick::colorizeimage</refname>
  <refpurpose>Blends a color with the image</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>Gmagick::colorizeimage</methodname>
   <methodparam><type>mixed</type><parameter>colorize</parameter></methodparam>
   <methodparam><type class="union"><type>GmagickPixel</type><type>string</type></type><parameter>opacity</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Blends the fill color given by <parameter>colorize</parameter> with each pixel
   of the image. The <parameter>opacity</parameter> color controls, per channel,
   how strongly the colorize color is applied.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>colorize</parameter></term>
    <listitem>
     <simpara>
      The colorization color, as a <classname>GmagickPixel</classname> object or
      a color string.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>opacity</parameter></term>
    <listitem>
     <simpara>
      The opacity color determining, for each channel, how much of the colorize
      color is blended into the image.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns &true; on success.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws an <exceptionname>GmagickException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
