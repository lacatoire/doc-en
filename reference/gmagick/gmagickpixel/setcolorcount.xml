<refentry xml:id="gmagickpixel.setcolorcount" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>GmagickPixel::setcolorcount</refname>
  <refpurpose>Sets the color count associated with this color</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>GmagickPixel</type><methodname>GmagickPixel::setcolorcount</methodname>
   <methodparam><type>int</type><parameter>color_count</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Sets the number of occurrences of this color, as used when building a color histogram of an image.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>color_count</parameter></term>
    <listitem>
     <simpara>
      The number of times this color occurs.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>The <classname>GmagickPixel</classname> object.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Throws a <exceptionname>GmagickPixelException</exceptionname> on error.
  </simpara>
 </refsect1>
</refentry>
