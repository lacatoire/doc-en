<refentry xml:id="v8js.compilestring" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>V8Js::compileString</refname>
  <refpurpose>Compile a string as Javascript code</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>mixed</type><methodname>V8Js::compileString</methodname>
   <methodparam><type>string</type><parameter>script</parameter></methodparam>
   <methodparam choice="opt"><type>string</type><parameter>identifier</parameter></methodparam>
  </methodsynopsis>
  <para>
   Compiles the string passed with <parameter>script</parameter> as Javascript
   code and returns a script resource that can be run with
   <methodname>V8Js::executeScript</methodname>.
  </para>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>script</parameter></term>
    <listitem>
     <simpara>
      The code string to be compiled.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>identifier</parameter></term>
    <listitem>
     <simpara>
      Identifier string for the compiled code. Used for debugging.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns a script resource for the compiled code.
  </simpara>
 </refsect1>
</refentry>

