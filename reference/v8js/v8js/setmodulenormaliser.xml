<refentry xml:id="v8js.setmodulenormaliser" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>V8Js::setModuleNormaliser</refname>
  <refpurpose>Set the module normaliser callback</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>void</type><methodname>V8Js::setModuleNormaliser</methodname>
   <methodparam><type>string</type><parameter>base</parameter></methodparam>
   <methodparam><type>string</type><parameter>module_id</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Sets the normalisation used to resolve module identifiers for the module
   loader.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>base</parameter></term>
    <listitem>
     <simpara>
      The base path used to normalise module identifiers.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>module_id</parameter></term>
    <listitem>
     <simpara>
      The module identifier to normalise.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   &return.void;
  </simpara>
 </refsect1>
</refentry>

