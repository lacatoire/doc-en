<refentry xml:id="v8js.settimelimit" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>V8Js::setTimeLimit</refname>
  <refpurpose>Set the time limit for Javascript execution</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>void</type><methodname>V8Js::setTimeLimit</methodname>
   <methodparam><type>int</type><parameter>time_limit</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Sets the time limit, in milliseconds, applied to subsequent Javascript
   executions.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>time_limit</parameter></term>
    <listitem>
     <simpara>
      The time limit in milliseconds.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   &return.void;
  </simpara>
 </refsect1>
</refentry>

