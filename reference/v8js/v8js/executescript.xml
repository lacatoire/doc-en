<refentry xml:id="v8js.executescript" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>V8Js::executeScript</refname>
  <refpurpose>Execute a compiled script</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>mixed</type><methodname>V8Js::executeScript</methodname>
   <methodparam><type>resource</type><parameter>script</parameter></methodparam>
   <methodparam choice="opt"><type>int</type><parameter>flags</parameter></methodparam>
   <methodparam choice="opt"><type>int</type><parameter>time_limit</parameter></methodparam>
   <methodparam choice="opt"><type>int</type><parameter>memory_limit</parameter></methodparam>
  </methodsynopsis>
  <para>
   Executes a script resource previously compiled with
   <methodname>V8Js::compileString</methodname>.
  </para>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>script</parameter></term>
    <listitem>
     <simpara>
      The compiled script resource to be executed.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>flags</parameter></term>
    <listitem>
     <simpara>
      Execution flags. This value must be one of the
      <literal>V8Js::FLAG_*</literal> constants.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>time_limit</parameter></term>
    <listitem>
     <simpara>
      The time limit in milliseconds for the execution.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>memory_limit</parameter></term>
    <listitem>
     <simpara>
      The memory limit in bytes for the execution.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns the last variable instantiated in the Javascript code converted to matching PHP variable type.
  </simpara>
 </refsect1>
</refentry>

