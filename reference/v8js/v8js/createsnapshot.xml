<refentry xml:id="v8js.createsnapshot" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>V8Js::createSnapshot</refname>
  <refpurpose>Create a V8 heap snapshot from a script</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <modifier>static</modifier> <type class="union"><type>string</type><type>bool</type></type><methodname>V8Js::createSnapshot</methodname>
   <methodparam><type>string</type><parameter>script</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Creates a V8 heap snapshot from the given script, which can then be passed
   to <function>V8Js::__construct</function> to initialise a context.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>script</parameter></term>
    <listitem>
     <simpara>
      The Javascript code to embed into the snapshot.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns the snapshot as a string on success, or &false; on failure.
  </simpara>
 </refsect1>
</refentry>

