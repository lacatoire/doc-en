<refentry xml:id="gearmanworker.enableexceptionhandler" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>GearmanWorker::enableExceptionHandler</refname>
  <refpurpose>Enable exception forwarding for the worker</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis role="GearmanWorker">
   <modifier>public</modifier> <type>bool</type><methodname>GearmanWorker::enableExceptionHandler</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Enables the exception handler by requesting the <literal>exceptions</literal>
   option from the job server, so that exceptions thrown by the worker can be
   forwarded to the client.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success, or &false; on failure.
  </simpara>
 </refsect1>

 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><methodname>GearmanClient::enableExceptionHandler</methodname></member>
  </simplelist>
 </refsect1>

</refentry>
