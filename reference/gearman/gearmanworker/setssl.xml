<refentry xml:id="gearmanworker.setssl" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>GearmanWorker::setSSL</refname>
  <refpurpose>Enable SSL for the worker connection</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis role="GearmanWorker">
   <modifier>public</modifier> <type>bool</type><methodname>GearmanWorker::setSSL</methodname>
   <methodparam choice="opt"><type>bool</type><parameter>ssl</parameter><initializer>&true;</initializer></methodparam>
   <methodparam choice="opt"><type class="union"><type>string</type><type>null</type></type><parameter>ca_file</parameter><initializer>&null;</initializer></methodparam>
   <methodparam choice="opt"><type class="union"><type>string</type><type>null</type></type><parameter>certificate</parameter><initializer>&null;</initializer></methodparam>
   <methodparam choice="opt"><type class="union"><type>string</type><type>null</type></type><parameter>key_file</parameter><initializer>&null;</initializer></methodparam>
  </methodsynopsis>
  <simpara>
   Enables or disables SSL for the connection to the job server and configures
   the certificate files it uses.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>ssl</parameter></term>
    <listitem>
     <simpara>
      Whether SSL should be enabled for the connection.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>ca_file</parameter></term>
    <listitem>
     <simpara>
      Path to the certificate authority (CA) file.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>certificate</parameter></term>
    <listitem>
     <simpara>
      Path to the certificate file.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>key_file</parameter></term>
    <listitem>
     <simpara>
      Path to the private key file.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success, or &false; on failure.
  </simpara>
 </refsect1>

 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><methodname>GearmanWorker::addServer</methodname></member>
  </simplelist>
 </refsect1>

</refentry>
