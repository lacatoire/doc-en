<refentry xml:id="gearmanclient.enableexceptionhandler" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>GearmanClient::enableExceptionHandler</refname>
  <refpurpose>Enable forwarding of worker exceptions to the client</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis role="GearmanClient">
   <modifier>public</modifier> <type>bool</type><methodname>GearmanClient::enableExceptionHandler</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Enables the exception handler by requesting the <literal>exceptions</literal>
   option from the job server. When enabled, exceptions thrown by a worker are
   forwarded by the server to the client.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success, or &false; on failure.
  </simpara>
 </refsect1>

</refentry>
