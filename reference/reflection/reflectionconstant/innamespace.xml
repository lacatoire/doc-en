<refentry xml:id="reflectionconstant.innamespace" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>ReflectionConstant::inNamespace</refname>
  <refpurpose>Checks if in namespace</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis role="ReflectionConstant">
   <modifier>public</modifier> <type>bool</type><methodname>ReflectionConstant::inNamespace</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Checks whether this constant is defined in a namespace.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; if the constant is defined in a namespace, &false; otherwise.
  </simpara>
 </refsect1>

 <refsect1 role="examples">
  &reftitle.examples;
  <example>
   <title><methodname>ReflectionConstant::inNamespace</methodname> example</title>
   <programlisting role="php">
<![CDATA[
<?php
namespace App;

const GREETING = 'hello';

var_dump((new \ReflectionConstant('App\\GREETING'))->inNamespace());
var_dump((new \ReflectionConstant('PHP_VERSION'))->inNamespace());
?>
]]>
   </programlisting>
   &example.outputs;
   <screen>
<![CDATA[
bool(true)
bool(false)
]]>
   </screen>
  </example>
 </refsect1>

 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><methodname>ReflectionConstant::getNamespaceName</methodname></member>
   <member><methodname>ReflectionConstant::getShortName</methodname></member>
  </simplelist>
 </refsect1>

</refentry>
