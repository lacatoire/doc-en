<refentry xml:id="memcached.getlastdisconnectedserver" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Memcached::getLastDisconnectedServer</refname>
  <refpurpose>Get the last disconnected server</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis role="Memcached">
   <modifier>public</modifier> <type class="union"><type>array</type><type>false</type></type><methodname>Memcached::getLastDisconnectedServer</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Returns the server that most recently disconnected while a command was being sent to it.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns an array with the <literal>host</literal>, <literal>port</literal> and <literal>weight</literal> of the last server for which the connection was lost, or &false; on failure.
  </simpara>
 </refsect1>

 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><methodname>Memcached::getResultCode</methodname></member>
  </simplelist>
 </refsect1>

</refentry>
