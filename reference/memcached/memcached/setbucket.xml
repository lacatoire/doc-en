<refentry xml:id="memcached.setbucket" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Memcached::setBucket</refname>
  <refpurpose>Set the buckets for consistent hashing</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis role="Memcached">
   <modifier>public</modifier> <type>bool</type><methodname>Memcached::setBucket</methodname>
   <methodparam><type>array</type><parameter>host_map</parameter></methodparam>
   <methodparam><type class="union"><type>array</type><type>null</type></type><parameter>forward_map</parameter></methodparam>
   <methodparam><type>int</type><parameter>replicas</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Sets the buckets used for consistent hashing, mapping server indexes to buckets.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>host_map</parameter></term>
    <listitem>
     <simpara>
      An array mapping bucket positions to server indexes.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>forward_map</parameter></term>
    <listitem>
     <simpara>
      An optional array mapping bucket positions used for the forward map, or &null;.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>replicas</parameter></term>
    <listitem>
     <simpara>
      The number of replicas.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   &return.success;
  </simpara>
 </refsect1>

 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><methodname>Memcached::addServers</methodname></member>
  </simplelist>
 </refsect1>

</refentry>
