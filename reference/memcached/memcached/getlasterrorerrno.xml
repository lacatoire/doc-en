<refentry xml:id="memcached.getlasterrorerrno" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Memcached::getLastErrorErrno</refname>
  <refpurpose>Get the errno of the last error</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis role="Memcached">
   <modifier>public</modifier> <type>int</type><methodname>Memcached::getLastErrorErrno</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Returns the <literal>errno</literal> associated with the last error that occurred.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns the <literal>errno</literal> of the last error that occurred.
  </simpara>
 </refsect1>

 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><methodname>Memcached::getLastErrorCode</methodname></member>
   <member><methodname>Memcached::getLastErrorMessage</methodname></member>
  </simplelist>
 </refsect1>

</refentry>
