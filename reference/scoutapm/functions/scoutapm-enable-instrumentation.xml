<refentry xml:id="function.scoutapm-enable-instrumentation" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>scoutapm_enable_instrumentation</refname>
  <refpurpose>Enable or disable instrumentation at runtime.</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type>void</type><methodname>scoutapm_enable_instrumentation</methodname>
   <methodparam><type>bool</type><parameter>enable</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Turns all instrumentation performed by the scoutapm extension on or off
   for the rest of the current request.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>enable</parameter></term>
    <listitem>
     <simpara>
      Whether instrumentation should be enabled (&true;) or disabled
      (&false;).
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   &return.void;
  </simpara>
 </refsect1>

 <refsect1 role="examples">
  &reftitle.examples;
  <example>
   <title>Disable instrumentation around a section of code</title>
   <programlisting role="php">
<![CDATA[
<?php
scoutapm_enable_instrumentation(false);

// Work performed here is not instrumented by scoutapm.

scoutapm_enable_instrumentation(true);
?>
]]>
   </programlisting>
  </example>
 </refsect1>

 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>scoutapm_get_calls</function></member>
   <member><function>scoutapm_list_instrumented_functions</function></member>
  </simplelist>
 </refsect1>

</refentry>
