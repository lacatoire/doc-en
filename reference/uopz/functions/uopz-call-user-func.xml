<refentry xml:id="function.uopz-call-user-func" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>uopz_call_user_func</refname>
  <refpurpose>Call a callback with the registered hooks honoured</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type>mixed</type><methodname>uopz_call_user_func</methodname>
   <methodparam><type>callable</type><parameter>callback</parameter></methodparam>
   <methodparam rep="repeat"><type>mixed</type><parameter>args</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Calls the <parameter>callback</parameter> with the given arguments, honouring
   any hooks registered with <function>uopz_set_hook</function>.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>callback</parameter></term>
    <listitem>
     <simpara>
      The callable to be called.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>args</parameter></term>
    <listitem>
     <simpara>
      Zero or more parameters to be passed to the callback.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns the return value of the callback.
  </simpara>
 </refsect1>

 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>uopz_call_user_func_array</function></member>
   <member><function>uopz_set_hook</function></member>
  </simplelist>
 </refsect1>

</refentry>
