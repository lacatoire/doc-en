<refentry xml:id="zmqauth.construct" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>ZMQAuth::__construct</refname>
  <refpurpose>Construct a new ZMQAuth object</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <methodname>ZMQAuth::__construct</methodname>
   <methodparam><type>ZMQContext</type><parameter>ZMQContext</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Creates a new <classname>ZMQAuth</classname> object, a CurveZMQ / ZAP
   authentication handler bound to the given <classname>ZMQContext</classname>.
   The handler takes over authentication for all incoming connections in that
   context. Added in ZMQ extension version 1.1.3.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>ZMQContext</parameter></term>
    <listitem>
     <simpara>
      The <classname>ZMQContext</classname> for which this handler takes over
      authentication.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   No value is returned.
  </simpara>
 </refsect1>
</refentry>
