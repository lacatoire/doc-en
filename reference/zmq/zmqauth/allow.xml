<refentry xml:id="zmqauth.allow" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>ZMQAuth::allow</refname>
  <refpurpose>Add an address to the whitelist</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>ZMQAuth</type><methodname>ZMQAuth::allow</methodname>
   <methodparam><type>string</type><parameter>address</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Adds an address to the whitelist. Once a whitelist is defined, only
   whitelisted addresses are accepted. Added in ZMQ extension version 1.1.3.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>address</parameter></term>
    <listitem>
     <simpara>
      The address to whitelist.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns the current object.
  </simpara>
 </refsect1>
</refentry>
