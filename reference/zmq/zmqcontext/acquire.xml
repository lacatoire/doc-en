<refentry xml:id="zmqcontext.acquire" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>ZMQContext::acquire</refname>
  <refpurpose>Acquire a handle to the request global context</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <modifier>static</modifier> <type>ZMQContext</type><methodname>ZMQContext::acquire</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Acquires a handle to the process-global persistent context. Added in ZMQ extension version 1.1.3.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns a <classname>ZMQContext</classname> object.
  </simpara>
 </refsect1>

</refentry>

