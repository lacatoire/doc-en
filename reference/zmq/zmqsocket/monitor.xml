<refentry xml:id="zmqsocket.monitor" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>ZMQSocket::monitor</refname>
  <refpurpose>Start socket event monitoring</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>ZMQSocket</type><methodname>ZMQSocket::monitor</methodname>
   <methodparam><type>string</type><parameter>dsn</parameter></methodparam>
   <methodparam choice="opt"><type>int</type><parameter>events</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Starts publishing socket events (connect, disconnect, etc.) over the given <parameter>dsn</parameter> endpoint, which can then be read with a socket using <function>ZMQSocket::recvevent</function>. Added in ZMQ extension version 1.1.3.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>dsn</parameter></term>
    <listitem>
     <simpara>
      An inproc endpoint (for example <literal>inproc://monitor</literal>) over which socket events are emitted.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>events</parameter></term>
    <listitem>
     <simpara>
      A bitmask of the socket events to monitor. Defaults to all events.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns the current object.
  </simpara>
 </refsect1>

</refentry>

