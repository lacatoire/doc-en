<refentry xml:id="zmqcert.apply" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>ZMQCert::apply</refname>
  <refpurpose>Apply the certificate to a socket</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <methodname>ZMQCert::apply</methodname>
   <methodparam><type>ZMQSocket</type><parameter>socket</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Applies the certificate to the given <classname>ZMQSocket</classname>, setting
   the socket's CURVE public and secret keys from this certificate.
   Added in ZMQ extension version 1.1.3.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>socket</parameter></term>
    <listitem>
     <simpara>The <classname>ZMQSocket</classname> to configure with this certificate.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>No value is returned.</simpara>
 </refsect1>
</refentry>
