<refentry xml:id="function.dio-fdopen" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>dio_fdopen</refname>
  <refpurpose>Opens a stream for an existing file descriptor</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type class="union"><type>resource</type><type>false</type></type><methodname>dio_fdopen</methodname>
   <methodparam><type>int</type><parameter>fd</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   <function>dio_fdopen</function> returns a direct I/O resource wrapping an
   existing UNIX-style integer file descriptor, so that it can be used with the
   other <literal>dio_*</literal> functions.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>fd</parameter></term>
    <listitem>
     <simpara>
      An integer file descriptor.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns a new direct I/O file descriptor resource on success, or &false; if
   <parameter>fd</parameter> is not a valid file descriptor.
  </simpara>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>dio_open</function></member>
   <member><function>dio_dup</function></member>
  </simplelist>
 </refsect1>
</refentry>
