<refentry xml:id="function.dio-serial" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>dio_serial</refname>
  <refpurpose>Opens a stream for a serial port</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type class="union"><type>resource</type><type>false</type></type><methodname>dio_serial</methodname>
   <methodparam><type>string</type><parameter>filename</parameter></methodparam>
   <methodparam><type>string</type><parameter>mode</parameter></methodparam>
   <methodparam choice="opt"><type>array</type><parameter>options</parameter><initializer>&null;</initializer></methodparam>
  </methodsynopsis>
  <simpara>
   <function>dio_serial</function> opens a serial port and returns a stream,
   configuring the line according to the <parameter>options</parameter> array.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>filename</parameter></term>
    <listitem>
     <simpara>
      The pathname of the serial port to open (for example
      <literal>/dev/ttyS0</literal>).
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>mode</parameter></term>
    <listitem>
     <simpara>
      The access mode, as used by <function>fopen</function> (for example
      <literal>r</literal>, <literal>w</literal> or <literal>r+</literal>).
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>options</parameter></term>
    <listitem>
     <simpara>
      An associative array which may contain the following keys, in addition to
      the keys accepted by <function>dio_raw</function> (<literal>perms</literal>,
      <literal>is_blocking</literal>, <literal>timeout_secs</literal> and
      <literal>timeout_usecs</literal>):
     </simpara>
     <itemizedlist>
      <listitem>
       <simpara>
        <literal>data_rate</literal> (<type>int</type>) - the baud rate, one of
        <literal>0</literal>, <literal>50</literal>, <literal>75</literal>,
        <literal>110</literal>, <literal>134</literal>, <literal>150</literal>,
        <literal>200</literal>, <literal>300</literal>, <literal>600</literal>,
        <literal>1200</literal>, <literal>1800</literal>, <literal>2400</literal>,
        <literal>4800</literal>, <literal>9600</literal>, <literal>19200</literal>,
        <literal>38400</literal>, <literal>57600</literal>,
        <literal>115200</literal>, <literal>230400</literal> or
        <literal>460800</literal>.
       </simpara>
      </listitem>
      <listitem>
       <simpara>
        <literal>data_bits</literal> (<type>int</type>) - the number of data
        bits, one of <literal>5</literal>, <literal>6</literal>,
        <literal>7</literal> or <literal>8</literal>.
       </simpara>
      </listitem>
      <listitem>
       <simpara>
        <literal>stop_bits</literal> (<type>int</type>) - the number of stop
        bits, either <literal>1</literal> or <literal>2</literal>.
       </simpara>
      </listitem>
      <listitem>
       <simpara>
        <literal>parity</literal> (<type>int</type>) - the parity, one of
        <literal>0</literal> (none), <literal>1</literal> (odd) or
        <literal>2</literal> (even).
       </simpara>
      </listitem>
      <listitem>
       <simpara>
        <literal>flow_control</literal> (<type>int</type>) - set to
        <literal>1</literal> to enable hardware flow control, or
        <literal>0</literal> to disable it.
       </simpara>
      </listitem>
      <listitem>
       <simpara>
        <literal>is_canonical</literal> (<type>int</type>) - set to
        <literal>1</literal> to put the port in canonical mode, or
        <literal>0</literal> for raw mode.
       </simpara>
      </listitem>
     </itemizedlist>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns a stream resource on success, or &false; on failure.
  </simpara>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>dio_raw</function></member>
   <member><function>dio_tcsetattr</function></member>
  </simplelist>
 </refsect1>
</refentry>
