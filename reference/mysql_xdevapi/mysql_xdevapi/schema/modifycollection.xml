<refentry xml:id="mysql-xdevapi-schema.modifycollection" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Schema::modifyCollection</refname>
  <refpurpose>Modify a collection</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>mysql_xdevapi\Schema::modifyCollection</methodname>
   <methodparam><type>string</type><parameter>name</parameter></methodparam>
   <methodparam><type>string</type><parameter>options</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Modifies an existing collection in the schema, applying the given
   <parameter>options</parameter>. It is used to set or update the collection's
   schema validation, that is its validation level and JSON schema.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>name</parameter></term>
    <listitem>
     <simpara>
      The name of the collection to modify.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>options</parameter></term>
    <listitem>
     <simpara>
      The options to apply, as a JSON object; for example the validation
      level and the JSON schema used to validate the collection's documents.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success, or &false; on failure.
  </simpara>
 </refsect1>

 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><methodname>mysql_xdevapi\Schema::createCollection</methodname></member>
   <member><methodname>mysql_xdevapi\Schema::dropCollection</methodname></member>
  </simplelist>
 </refsect1>

</refentry>
