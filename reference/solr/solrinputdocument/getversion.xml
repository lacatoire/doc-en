<refentry xml:id="solrinputdocument.getversion" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>SolrInputDocument::getVersion</refname>
  <refpurpose>Gets the version of the document</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>int</type><methodname>SolrInputDocument::getVersion</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Gets the value of the <literal>_version_</literal> field of the document,
   which is used by Solr for optimistic concurrency control.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns the document version as an <type>int</type>, or &null; if the
   <literal>_version_</literal> field has not been set.
  </simpara>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><methodname>SolrInputDocument::setVersion</methodname></member>
  </simplelist>
 </refsect1>
</refentry>
