 <title>The SolrExtractRequest class</title>
 <titleabbrev>SolrExtractRequest</titleabbrev>

 <partintro>

<!-- {{{ SolrExtractRequest intro -->
  <section xml:id="solrextractrequest.intro">
   &reftitle.intro;
   <simpara>
    Represents a request to extract text and metadata from a rich document
    (such as a PDF or a Microsoft Office file) using the Solr
    <literal>ExtractingRequestHandler</literal>. An instance is created with
    one of the static factory methods and then sent to the server with
    <methodname>SolrClient::sendUpdateStream</methodname>.
   </simpara>
  </section>
<!-- }}} -->

