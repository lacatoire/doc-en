<refentry xml:id="solrresponse.getarrayresponse" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>SolrResponse::getArrayResponse</refname>
  <refpurpose>Returns the response as an array</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>array</type><methodname>SolrResponse::getArrayResponse</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Returns the raw response from the server parsed into an array, instead of
   into the object returned by <methodname>SolrResponse::getResponse</methodname>.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   The response represented as an array.
  </simpara>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><methodname>SolrResponse::getResponse</methodname></member>
   <member><methodname>SolrResponse::getRawResponse</methodname></member>
  </simplelist>
 </refsect1>
</refentry>
