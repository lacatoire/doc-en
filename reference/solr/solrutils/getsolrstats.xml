<refentry xml:id="solrutils.getsolrstats" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>SolrUtils::getSolrStats</refname>
  <refpurpose>Returns the number of active Solr objects</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <modifier>static</modifier> <type>array</type><methodname>SolrUtils::getSolrStats</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Returns the number of active <classname>SolrDocument</classname>,
   <classname>SolrClient</classname> and <classname>SolrParams</classname>
   objects in the current thread.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   An array with the keys <literal>document_count</literal>,
   <literal>client_count</literal> and <literal>params_count</literal>, holding
   respectively the number of active documents, clients and parameter objects.
  </simpara>
 </refsect1>
</refentry>
