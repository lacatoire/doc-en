<refentry xml:id="solrutils.digestjsonresponse" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>SolrUtils::digestJsonResponse</refname>
  <refpurpose>Parses a response JSON string into a SolrObject</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <modifier>static</modifier> <type>SolrObject</type><methodname>SolrUtils::digestJsonResponse</methodname>
   <methodparam><type>string</type><parameter>jsonResponse</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Parses a JSON response string from the Apache Solr server into a
   <classname>SolrObject</classname>. It is the JSON counterpart of
   <methodname>SolrUtils::digestXmlResponse</methodname>.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>jsonResponse</parameter></term>
    <listitem>
     <simpara>
      The JSON response string from the Solr server.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns the <classname>SolrObject</classname> representing the JSON response.
  </simpara>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><methodname>SolrUtils::digestXmlResponse</methodname></member>
  </simplelist>
 </refsect1>
</refentry>
