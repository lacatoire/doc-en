<refentry xml:id="solrextractrequest.createfromstream" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>SolrExtractRequest::createFromStream</refname>
  <refpurpose>Creates an extract request from raw content</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <modifier>static</modifier> <type>SolrExtractRequest</type><methodname>SolrExtractRequest::createFromStream</methodname>
   <methodparam><type>string</type><parameter>content</parameter></methodparam>
   <methodparam><type>string</type><parameter>mime_type</parameter></methodparam>
   <methodparam><type>SolrModifiableParams</type><parameter>params</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Builds a <classname>SolrExtractRequest</classname> that extracts content
   from the raw document held in <parameter>content</parameter>. Because the
   content is passed directly, its <parameter>mime_type</parameter> has to be
   supplied so that the server can select the right extraction handler.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>content</parameter></term>
    <listitem>
     <simpara>
      The raw content of the document whose text is to be extracted.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>mime_type</parameter></term>
    <listitem>
     <simpara>
      The MIME type of <parameter>content</parameter>, for example
      <literal>application/pdf</literal>.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>params</parameter></term>
    <listitem>
     <simpara>
      The extraction parameters to send with the request.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   A <classname>SolrExtractRequest</classname> instance, ready to be passed to
   <methodname>SolrClient::sendUpdateStream</methodname>.
  </simpara>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><methodname>SolrExtractRequest::createFromFile</methodname></member>
   <member><methodname>SolrClient::sendUpdateStream</methodname></member>
  </simplelist>
 </refsect1>
</refentry>
