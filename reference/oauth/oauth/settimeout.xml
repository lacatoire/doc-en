<refentry xml:id="oauth.settimeout" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>OAuth::setTimeout</refname>
  <refpurpose>Set the timeout for requests</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>OAuth::setTimeout</methodname>
   <methodparam><type>int</type><parameter>timeout_in_milliseconds</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Sets the timeout, in milliseconds, for all subsequent requests. The value is
   applied to both the connection and the transfer of each HTTP request.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>timeout_in_milliseconds</parameter></term>
    <listitem>
     <simpara>
      The timeout, in milliseconds. Must be a non-negative integer.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success.
  </simpara>
 </refsect1>

 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   Emits an <exceptionname>OAuthException</exceptionname> exception if
   <parameter>timeout_in_milliseconds</parameter> is negative.
  </simpara>
 </refsect1>

 <refsect1 role="examples">
  &reftitle.examples;
  <example>
   <title><function>OAuth::setTimeout</function> example</title>
   <programlisting role="php">
<![CDATA[
<?php
$oauth = new OAuth("consumer_key", "consumer_secret");

// Abort requests that take longer than 5 seconds
$oauth->setTimeout(5000);
?>
]]>
   </programlisting>
  </example>
 </refsect1>

 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><methodname>OAuth::setRequestEngine</methodname></member>
   <member><methodname>OAuth::fetch</methodname></member>
   <member><exceptionname>OAuthException</exceptionname></member>
  </simplelist>
 </refsect1>
</refentry>
