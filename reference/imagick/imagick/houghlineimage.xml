<refentry xml:id="imagick.houghlineimage" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::houghLineImage</refname>
  <refpurpose>Identifies lines in the image with a Hough transform</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type> <methodname>Imagick::houghLineImage</methodname>
   <methodparam><type>int</type><parameter>width</parameter></methodparam>
   <methodparam><type>int</type><parameter>height</parameter></methodparam>
   <methodparam><type>float</type><parameter>threshold</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Uses a Hough line detector to identify straight lines in the image and
   superimposes them on it. It is typically applied to the output of an edge
   detector.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>width</parameter></term>
    <listitem>
     <simpara>
      The width of the neighborhood used to search for lines.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>height</parameter></term>
    <listitem>
     <simpara>
      The height of the neighborhood used to search for lines.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>threshold</parameter></term>
    <listitem>
     <simpara>
      The minimum number of votes a line must receive to be retained.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
