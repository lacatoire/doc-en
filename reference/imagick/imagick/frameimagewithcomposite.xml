<refentry xml:id="imagick.frameimagewithcomposite" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::frameImageWithComposite</refname>
  <refpurpose>Adds a simulated 3D border, using a composite operator</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type> <methodname>Imagick::frameImageWithComposite</methodname>
   <methodparam><type class="union"><type>ImagickPixel</type><type>string</type></type><parameter>matte_color</parameter></methodparam>
   <methodparam><type>int</type><parameter>width</parameter></methodparam>
   <methodparam><type>int</type><parameter>height</parameter></methodparam>
   <methodparam><type>int</type><parameter>inner_bevel</parameter></methodparam>
   <methodparam><type>int</type><parameter>outer_bevel</parameter></methodparam>
   <methodparam><type>int</type><parameter>composite</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Adds a simulated three-dimensional border around the image. This behaves
   like <methodname>Imagick::frameImage</methodname> but additionally lets the
   caller select the composite operator used to draw the frame onto the image.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>matte_color</parameter></term>
    <listitem>
     <simpara>
      The frame (matte) color. An <classname>ImagickPixel</classname> object or
      a color string.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>width</parameter></term>
    <listitem>
     <simpara>
      The width of the frame, in pixels.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>height</parameter></term>
    <listitem>
     <simpara>
      The height of the frame, in pixels.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>inner_bevel</parameter></term>
    <listitem>
     <simpara>
      The width of the inner bevel of the frame, in pixels.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>outer_bevel</parameter></term>
    <listitem>
     <simpara>
      The width of the outer bevel of the frame, in pixels.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>composite</parameter></term>
    <listitem>
     <simpara>
      One of the <constant>Imagick::COMPOSITE_*</constant> constants
      controlling how the frame is composited onto the image.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
