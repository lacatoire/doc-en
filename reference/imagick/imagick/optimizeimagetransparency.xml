<refentry xml:id="imagick.optimizeimagetransparency" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::optimizeImageTransparency</refname>
  <refpurpose>Optimizes the transparency of an image sequence</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <methodname>Imagick::optimizeImageTransparency</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Optimizes the transparency of a sequence of images, such as an animation.
   Pixels that do not change from one frame to the next are made transparent,
   which can reduce the size of the resulting file.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   No value is returned.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
