<refentry xml:id="imagick.getimagerange" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::getImageRange</refname>
  <refpurpose>Gets the range of the image</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>array</type> <methodname>Imagick::getImageRange</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Gets the range of the current image, that is the lowest and highest pixel
   values actually present across all channels.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns an associative array with the keys <literal>minima</literal> and
   <literal>maxima</literal>, holding the minimum and maximum pixel values as
   floats in the range 0 to <constant>Imagick::QUANTUM_RANGE</constant>.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
