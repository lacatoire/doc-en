<refentry xml:id="imagick.setimagepixelcolor" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::setImagePixelColor</refname>
  <refpurpose>Sets the color of the specified pixel</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>ImagickPixel</type> <methodname>Imagick::setImagePixelColor</methodname>
   <methodparam><type>int</type><parameter>x</parameter></methodparam>
   <methodparam><type>int</type><parameter>y</parameter></methodparam>
   <methodparam><type class="union"><type>ImagickPixel</type><type>string</type></type><parameter>color</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Sets the color of the single pixel located at the given coordinate in the
   current image.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>x</parameter></term>
    <listitem>
     <simpara>
      The x coordinate of the pixel.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>y</parameter></term>
    <listitem>
     <simpara>
      The y coordinate of the pixel.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>color</parameter></term>
    <listitem>
     <simpara>
      The color to set. An <classname>ImagickPixel</classname> object or a
      color string.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns an <classname>ImagickPixel</classname> object for the pixel that was
   set.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
