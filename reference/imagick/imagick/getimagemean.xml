<refentry xml:id="imagick.getimagemean" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::getImageMean</refname>
  <refpurpose>Gets the mean and standard deviation of the image</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>array</type><methodname>Imagick::getImageMean</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Gets the mean and standard deviation of the current image.
  </simpara>
  <warning>
   <simpara>
    This method is available if Imagick has been compiled against ImageMagick
    version 7 or newer.
   </simpara>
  </warning>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns an array with the keys <literal>mean</literal> and <literal>standardDeviation</literal>.
  </simpara>
 </refsect1>

 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><methodname>Imagick::getImageKurtosis</methodname></member>
  </simplelist>
 </refsect1>

</refentry>
