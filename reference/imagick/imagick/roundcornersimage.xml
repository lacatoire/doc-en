<refentry xml:id="imagick.roundcornersimage" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::roundCornersImage</refname>
  <refpurpose>Rounds the corners of the image</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type> <methodname>Imagick::roundCornersImage</methodname>
   <methodparam><type>float</type><parameter>x_rounding</parameter></methodparam>
   <methodparam><type>float</type><parameter>y_rounding</parameter></methodparam>
   <methodparam choice="opt"><type>float</type><parameter>stroke_width</parameter><initializer>10</initializer></methodparam>
   <methodparam choice="opt"><type>float</type><parameter>displace</parameter><initializer>5</initializer></methodparam>
   <methodparam choice="opt"><type>float</type><parameter>size_correction</parameter><initializer>-6</initializer></methodparam>
  </methodsynopsis>
  <simpara>
   Rounds the corners of the image, cutting away the area outside the rounded
   rectangle and making it transparent. The horizontal and vertical corner
   radii are given separately.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>x_rounding</parameter></term>
    <listitem>
     <simpara>
      The horizontal rounding radius, in pixels.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>y_rounding</parameter></term>
    <listitem>
     <simpara>
      The vertical rounding radius, in pixels.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>stroke_width</parameter></term>
    <listitem>
     <simpara>
      The stroke width used when drawing the rounded rectangle.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>displace</parameter></term>
    <listitem>
     <simpara>
      The displacement applied to the corner shape.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>size_correction</parameter></term>
    <listitem>
     <simpara>
      A correction applied to the size of the rounded rectangle.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
