<refentry xml:id="imagick.setimagealpha" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::setImageAlpha</refname>
  <refpurpose>Sets the image opacity level</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type> <methodname>Imagick::setImageAlpha</methodname>
   <methodparam><type>float</type><parameter>alpha</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Sets the alpha (opacity) level of the whole image, where 0.0 is fully
   transparent and 1.0 is fully opaque.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>alpha</parameter></term>
    <listitem>
     <simpara>
      The level of transparency, from 0.0 (fully transparent) to 1.0 (fully
      opaque).
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
