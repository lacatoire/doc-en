<refentry xml:id="imagick.colorthresholdimage" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::colorThresholdImage</refname>
  <refpurpose>Forces all pixels within a color range to white, and the rest to black</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type> <methodname>Imagick::colorThresholdImage</methodname>
   <methodparam><type class="union"><type>ImagickPixel</type><type>string</type></type><parameter>start_color</parameter></methodparam>
   <methodparam><type class="union"><type>ImagickPixel</type><type>string</type></type><parameter>stop_color</parameter></methodparam>
  </methodsynopsis>
  <simpara>Sets every pixel whose color falls within the range defined by <parameter>start_color</parameter> and <parameter>stop_color</parameter> to white, and all other pixels to black.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>start_color</parameter></term>
    <listitem>
     <simpara>The lower bound of the color range.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>stop_color</parameter></term>
    <listitem>
     <simpara>The upper bound of the color range.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>&imagick.return.success;</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
