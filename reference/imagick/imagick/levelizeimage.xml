<refentry xml:id="imagick.levelizeimage" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::levelizeImage</refname>
  <refpurpose>Applies the reverse level operation to the image</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type> <methodname>Imagick::levelizeImage</methodname>
   <methodparam><type>float</type><parameter>black_point</parameter></methodparam>
   <methodparam><type>float</type><parameter>gamma</parameter></methodparam>
   <methodparam><type>float</type><parameter>white_point</parameter></methodparam>
  </methodsynopsis>
  <simpara>Applies the reverse of <methodname>Imagick::levelImage</methodname>, mapping the given black and white points back onto the full quantum range using the supplied gamma.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>black_point</parameter></term>
    <listitem>
     <simpara>The black point; input values at or below this are mapped to the low end of the range.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>gamma</parameter></term>
    <listitem>
     <simpara>The gamma value applied to the mid-tones.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>white_point</parameter></term>
    <listitem>
     <simpara>The white point; input values at or above this are mapped to the high end of the range.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>&imagick.return.success;</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
