<refentry xml:id="imagick.interpolativeresizeimage" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::interpolativeResizeImage</refname>
  <refpurpose>Resizes an image using the specified interpolation method</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type> <methodname>Imagick::interpolativeResizeImage</methodname>
   <methodparam><type>int</type><parameter>columns</parameter></methodparam>
   <methodparam><type>int</type><parameter>rows</parameter></methodparam>
   <methodparam><type>int</type><parameter>interpolate</parameter></methodparam>
  </methodsynopsis>
  <simpara>Resizes the image to the given dimensions using the specified pixel interpolation method.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>columns</parameter></term>
    <listitem>
     <simpara>The number of columns (width) of the resized image.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>rows</parameter></term>
    <listitem>
     <simpara>The number of rows (height) of the resized image.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>interpolate</parameter></term>
    <listitem>
     <simpara>The pixel interpolation method to use. One of the <constant>Imagick::INTERPOLATE_*</constant> constants.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>&imagick.return.success;</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
