<refentry xml:id="imagick.claheimage" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::claheImage</refname>
  <refpurpose>Enhances image contrast using CLAHE</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type> <methodname>Imagick::claheImage</methodname>
   <methodparam><type>int</type><parameter>width</parameter></methodparam>
   <methodparam><type>int</type><parameter>height</parameter></methodparam>
   <methodparam><type>int</type><parameter>number_bins</parameter></methodparam>
   <methodparam><type>float</type><parameter>clip_limit</parameter></methodparam>
  </methodsynopsis>
  <simpara>Applies Contrast Limited Adaptive Histogram Equalization (CLAHE) to the image, improving local contrast while limiting noise amplification in near-uniform regions.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>width</parameter></term>
    <listitem>
     <simpara>The width of the contextual (tile) region.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>height</parameter></term>
    <listitem>
     <simpara>The height of the contextual (tile) region.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>number_bins</parameter></term>
    <listitem>
     <simpara>The number of histogram bins used to build the mapping.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>clip_limit</parameter></term>
    <listitem>
     <simpara>The contrast limit, expressed as a slope; higher values allow greater contrast enhancement.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>&imagick.return.success;</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
