<refentry xml:id="imagick.polynomialimage" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::polynomialImage</refname>
  <refpurpose>Applies a polynomial function to the image</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type> <methodname>Imagick::polynomialImage</methodname>
   <methodparam><type>array</type><parameter>terms</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Combines the image channels by evaluating a weighted sum of powers of the
   pixel values, replacing each pixel with the result of the polynomial. This
   can be used, for example, to blend multiple images together.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>terms</parameter></term>
    <listitem>
     <simpara>
      A flat array of alternating coefficient and exponent values, one pair
      per term of the polynomial, for example
      <literal>[3, 0, -2, 1]</literal> for <literal>3&#42;x^0 - 2&#42;x^1</literal>.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
