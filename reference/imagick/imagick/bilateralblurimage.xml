<refentry xml:id="imagick.bilateralblurimage" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::bilateralBlurImage</refname>
  <refpurpose>Blurs an image using a bilateral, edge-preserving filter</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type> <methodname>Imagick::bilateralBlurImage</methodname>
   <methodparam><type>float</type><parameter>radius</parameter></methodparam>
   <methodparam><type>float</type><parameter>sigma</parameter></methodparam>
   <methodparam><type>float</type><parameter>intensity_sigma</parameter></methodparam>
   <methodparam><type>float</type><parameter>spatial_sigma</parameter></methodparam>
  </methodsynopsis>
  <simpara>Applies a bilateral blur to the image. This is an edge-preserving noise-reducing smoothing filter that averages nearby pixels weighted by both spatial distance and intensity difference.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>radius</parameter></term>
    <listitem>
     <simpara>The radius of the Gaussian, in pixels, not counting the center pixel.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>sigma</parameter></term>
    <listitem>
     <simpara>The standard deviation of the Gaussian, in pixels.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>intensity_sigma</parameter></term>
    <listitem>
     <simpara>The standard deviation used in the intensity (range) domain; larger values blur across greater tonal differences.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>spatial_sigma</parameter></term>
    <listitem>
     <simpara>The standard deviation used in the spatial (coordinate) domain.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>&imagick.return.success;</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
