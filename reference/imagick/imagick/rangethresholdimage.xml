<refentry xml:id="imagick.rangethresholdimage" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::rangeThresholdImage</refname>
  <refpurpose>Applies soft and hard thresholding to an image</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>Imagick::rangeThresholdImage</methodname>
   <methodparam><type>float</type><parameter>low_black</parameter></methodparam>
   <methodparam><type>float</type><parameter>low_white</parameter></methodparam>
   <methodparam><type>float</type><parameter>high_white</parameter></methodparam>
   <methodparam><type>float</type><parameter>high_black</parameter></methodparam>
  </methodsynopsis>
  <simpara>Applies a ranged threshold to the image. Pixel intensities below <parameter>low_black</parameter> or above <parameter>high_black</parameter> are set to black, intensities between <parameter>low_white</parameter> and <parameter>high_white</parameter> are set to white, and intensities in the intervening ranges are scaled smoothly between black and white.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>low_black</parameter></term>
    <listitem>
     <simpara>The intensity below which pixels are forced to black.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>low_white</parameter></term>
    <listitem>
     <simpara>The intensity at the lower end of the range above which pixels are forced to white.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>high_white</parameter></term>
    <listitem>
     <simpara>The intensity at the upper end of the range up to which pixels are forced to white.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>high_black</parameter></term>
    <listitem>
     <simpara>The intensity above which pixels are forced to black.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns &true; on success.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
