<refentry xml:id="imagick.key" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::key</refname>
  <refpurpose>Returns the index of the current active image</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>int</type> <methodname>Imagick::key</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Returns the index of the current active image within the sequence. This
   method implements part of the <classname>Iterator</classname> interface,
   allowing the object to be traversed with <literal>foreach</literal>.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns the index of the current image as an integer.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
