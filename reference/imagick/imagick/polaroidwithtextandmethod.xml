<refentry xml:id="imagick.polaroidwithtextandmethod" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::polaroidWithTextAndMethod</refname>
  <refpurpose>Simulates a Polaroid picture with a caption</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type> <methodname>Imagick::polaroidWithTextAndMethod</methodname>
   <methodparam><type>ImagickDraw</type><parameter>settings</parameter></methodparam>
   <methodparam><type>float</type><parameter>angle</parameter></methodparam>
   <methodparam><type>string</type><parameter>caption</parameter></methodparam>
   <methodparam><type>int</type><parameter>method</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Simulates a Polaroid picture, rotating the image by the given angle and
   drawing the supplied caption underneath it. The pixel interpolation method
   controls how the image is resampled while it is rotated.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>settings</parameter></term>
    <listitem>
     <simpara>
      An <classname>ImagickDraw</classname> object holding the font settings
      used to render the caption.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>angle</parameter></term>
    <listitem>
     <simpara>
      The angle, in degrees, by which the Polaroid is rotated.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>caption</parameter></term>
    <listitem>
     <simpara>
      The caption text drawn on the Polaroid.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>method</parameter></term>
    <listitem>
     <simpara>
      The pixel interpolation method, one of the
      <constant>Imagick::INTERPOLATE_*</constant> constants.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
