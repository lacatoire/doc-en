<refentry xml:id="imagick.addnoiseimagewithattenuate" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::addNoiseImageWithAttenuate</refname>
  <refpurpose>Adds random noise to the image</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type> <methodname>Imagick::addNoiseImageWithAttenuate</methodname>
   <methodparam><type>int</type><parameter>noise</parameter></methodparam>
   <methodparam><type>float</type><parameter>attenuate</parameter></methodparam>
   <methodparam choice="opt"><type>int</type><parameter>channel</parameter><initializer><constant>Imagick::CHANNEL_DEFAULT</constant></initializer></methodparam>
  </methodsynopsis>
  <simpara>
   Adds random noise to the image, using the given noise type and attenuation
   factor, optionally restricted to a set of channels.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>noise</parameter></term>
    <listitem>
     <simpara>
      The type of noise to add, one of the
      <constant>Imagick::NOISE_*</constant> constants.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>attenuate</parameter></term>
    <listitem>
     <simpara>
      The attenuation factor controlling the amount of noise applied.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>channel</parameter></term>
    <listitem>
     <simpara>
      The channels to affect, built from one or more
      <constant>Imagick::CHANNEL_*</constant> constants.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
