<refentry xml:id="imagick.autoorientate" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::autoOrientate</refname>
  <refpurpose>Adjusts an image so that its orientation is suitable for viewing</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>void</type><methodname>Imagick::autoOrientate</methodname>
   <void/>
  </methodsynopsis>
  <simpara>Adjusts the current image so that its orientation is suitable for viewing, rotating or flipping the pixel data according to the image's EXIF orientation attribute and resetting that attribute to the top-left default. This method is an alias of <methodname>Imagick::autoOrient</methodname>.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>No value is returned.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
