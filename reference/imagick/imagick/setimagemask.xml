<refentry xml:id="imagick.setimagemask" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::setImageMask</refname>
  <refpurpose>Sets the image clip mask</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>void</type><methodname>Imagick::setImageMask</methodname>
   <methodparam><type>Imagick</type><parameter>clip_mask</parameter></methodparam>
   <methodparam><type>int</type><parameter>pixelmask</parameter></methodparam>
  </methodsynopsis>
  <simpara>Sets the read or write pixel mask of the image from the given <classname>Imagick</classname> object. A pixel mask restricts subsequent operations to the pixels selected by the mask.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>clip_mask</parameter></term>
    <listitem>
     <simpara>The <classname>Imagick</classname> object whose grayscale intensities define the mask.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>pixelmask</parameter></term>
    <listitem>
     <simpara>The mask to set, either <constant>Imagick::PIXELMASK_READ</constant> or <constant>Imagick::PIXELMASK_WRITE</constant>.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>No value is returned.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
