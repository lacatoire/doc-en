<refentry xml:id="imagick.levelimagecolors" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::levelImageColors</refname>
  <refpurpose>Maps the black and white points of the image to the given colors</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type> <methodname>Imagick::levelImageColors</methodname>
   <methodparam><type class="union"><type>ImagickPixel</type><type>string</type></type><parameter>black_color</parameter></methodparam>
   <methodparam><type class="union"><type>ImagickPixel</type><type>string</type></type><parameter>white_color</parameter></methodparam>
   <methodparam><type>bool</type><parameter>invert</parameter></methodparam>
  </methodsynopsis>
  <simpara>Adjusts the levels of the image by scaling the colors so that <parameter>black_color</parameter> maps to black and <parameter>white_color</parameter> maps to white.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>black_color</parameter></term>
    <listitem>
     <simpara>The color to map to black.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>white_color</parameter></term>
    <listitem>
     <simpara>The color to map to white.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>invert</parameter></term>
    <listitem>
     <simpara>Whether to apply the inverse mapping, expanding the tonal range instead of contracting it.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>&imagick.return.success;</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
