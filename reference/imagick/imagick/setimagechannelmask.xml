<refentry xml:id="imagick.setimagechannelmask" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::setImageChannelMask</refname>
  <refpurpose>Sets the image channel mask</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>int</type> <methodname>Imagick::setImageChannelMask</methodname>
   <methodparam><type>int</type><parameter>channel</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Sets the channel mask of the image, which determines the channels that
   subsequent operations are applied to.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>channel</parameter></term>
    <listitem>
     <simpara>
      The channel mask, built from one or more
      <constant>Imagick::CHANNEL_*</constant> constants.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns the previous channel mask, as an integer built from the
   <constant>Imagick::CHANNEL_*</constant> constants.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
