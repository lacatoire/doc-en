<refentry xml:id="imagick.waveimagewithmethod" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::waveImageWithMethod</refname>
  <refpurpose>Applies a wave effect with the given interpolation method</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type> <methodname>Imagick::waveImageWithMethod</methodname>
   <methodparam><type>float</type><parameter>amplitude</parameter></methodparam>
   <methodparam><type>float</type><parameter>length</parameter></methodparam>
   <methodparam><type>int</type><parameter>interpolate_method</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Applies a wave-like distortion to the image, shifting pixels along a sine
   wave of the given amplitude and wavelength. The pixel interpolation method
   controls how new pixel values are computed.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>amplitude</parameter></term>
    <listitem>
     <simpara>
      The amplitude of the wave, in pixels.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>length</parameter></term>
    <listitem>
     <simpara>
      The wavelength of the wave, in pixels.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>interpolate_method</parameter></term>
    <listitem>
     <simpara>
      The pixel interpolation method, one of the
      <constant>Imagick::INTERPOLATE_*</constant> constants.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
