<refentry xml:id="imagick.compositeimagegravity" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::compositeImageGravity</refname>
  <refpurpose>Composite one image onto another at the specified gravity</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>Imagick::compositeImageGravity</methodname>
   <methodparam><type>Imagick</type><parameter>image</parameter></methodparam>
   <methodparam><type>int</type><parameter>composite_constant</parameter></methodparam>
   <methodparam><type>int</type><parameter>gravity</parameter></methodparam>
  </methodsynopsis>
  <simpara>Composites the given source image onto the current image using the specified composite operator, with the source positioned relative to the current image according to a gravity constant rather than explicit coordinates.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>image</parameter></term>
    <listitem>
     <simpara>The <classname>Imagick</classname> object holding the source image to composite onto the current image.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>composite_constant</parameter></term>
    <listitem>
     <simpara>The composite operator to use, as one of the <constant>Imagick::COMPOSITE_*</constant> constants.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>gravity</parameter></term>
    <listitem>
     <simpara>The placement of the source image, as one of the <constant>Imagick::GRAVITY_*</constant> constants.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns &true; on success.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
