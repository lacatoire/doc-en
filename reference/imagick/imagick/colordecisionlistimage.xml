<refentry xml:id="imagick.colordecisionlistimage" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::colorDecisionListImage</refname>
  <refpurpose>Applies a color correction from a Color Decision List</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type> <methodname>Imagick::colorDecisionListImage</methodname>
   <methodparam><type>string</type><parameter>color_correction_collection</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Applies a color correction to the image described by a Color Decision List
   (ASC CDL). The correction is expressed as an XML document that specifies
   slope, offset, power, and saturation adjustments.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>color_correction_collection</parameter></term>
    <listitem>
     <simpara>
      A string containing the Color Correction Collection in ColorCorrection
      XML format.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
