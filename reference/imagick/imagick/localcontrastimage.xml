<refentry xml:id="imagick.localcontrastimage" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::localContrastImage</refname>
  <refpurpose>Increase the local contrast of an image</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>Imagick::localContrastImage</methodname>
   <methodparam><type>float</type><parameter>radius</parameter></methodparam>
   <methodparam><type>float</type><parameter>strength</parameter></methodparam>
  </methodsynopsis>
  <simpara>Attempts to increase the appearance of large-scale light-dark transitions, enhancing local contrast in a manner similar to an unsharp mask applied at a large radius.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>radius</parameter></term>
    <listitem>
     <simpara>The radius, in pixels, of the Gaussian blur used to determine the local tonal average.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>strength</parameter></term>
    <listitem>
     <simpara>The strength of the effect, expressed as a percentage. Larger values produce a stronger contrast boost.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns &true; on success.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
