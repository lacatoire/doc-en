<refentry xml:id="imagick.autothresholdimage" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::autoThresholdImage</refname>
  <refpurpose>Automatically performs image thresholding</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type> <methodname>Imagick::autoThresholdImage</methodname>
   <methodparam><type>int</type><parameter>auto_threshold_method</parameter></methodparam>
  </methodsynopsis>
  <simpara>Automatically selects a threshold and reduces the image to black and white using the chosen thresholding algorithm.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>auto_threshold_method</parameter></term>
    <listitem>
     <simpara>The auto-threshold method to apply. One of the <constant>Imagick::AUTO_THRESHOLD_*</constant> constants (<constant>Imagick::AUTO_THRESHOLD_KAPUR</constant>, <constant>Imagick::AUTO_THRESHOLD_OTSU</constant> or <constant>Imagick::AUTO_THRESHOLD_TRIANGLE</constant>).</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>&imagick.return.success;</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
