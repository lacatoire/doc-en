<refentry xml:id="imagick.clutimagewithinterpolate" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::clutImageWithInterpolate</refname>
  <refpurpose>Replaces colors using a color lookup table</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type> <methodname>Imagick::clutImageWithInterpolate</methodname>
   <methodparam><type>Imagick</type><parameter>lookup_table</parameter></methodparam>
   <methodparam><type>int</type><parameter>pixel_interpolate_method</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Replaces the colors of the image with those defined by a color lookup table
   (CLUT), taken from another <classname>Imagick</classname> object. Each pixel
   value is used to index the lookup table, with the given interpolation method
   applied between entries.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>lookup_table</parameter></term>
    <listitem>
     <simpara>
      An <classname>Imagick</classname> object containing the color lookup
      table to apply.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>pixel_interpolate_method</parameter></term>
    <listitem>
     <simpara>
      The pixel interpolation method, one of the
      <constant>Imagick::INTERPOLATE_*</constant> constants.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
