<refentry xml:id="imagick.autogammaimage" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::autoGammaImage</refname>
  <refpurpose>Adjusts the gamma level of an image</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>void</type><methodname>Imagick::autoGammaImage</methodname>
   <methodparam choice="opt"><type class="union"><type>int</type><type>null</type></type><parameter>channel</parameter><initializer><constant>Imagick::CHANNEL_ALL</constant></initializer></methodparam>
  </methodsynopsis>
  <simpara>Extracts the mean and standard deviation of the image pixels and applies a gamma correction that stretches the tonal range so that the image achieves a balanced overall brightness.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>channel</parameter></term>
    <listitem>
     <simpara>The channel, or a bitmask of channels, to gamma-correct, as one of the <constant>Imagick::CHANNEL_*</constant> constants. Defaults to all channels.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>No value is returned.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
