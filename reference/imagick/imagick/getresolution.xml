<refentry xml:id="imagick.getresolution" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::getResolution</refname>
  <refpurpose>Gets the image resolution</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>array</type> <methodname>Imagick::getResolution</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Gets the horizontal and vertical resolution of the image, expressed in
   dots per inch (or the currently configured resolution unit).
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns an associative array with the keys <literal>x</literal> and
   <literal>y</literal>, holding the horizontal and vertical resolution as
   floats.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
