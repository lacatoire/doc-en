<refentry xml:id="imagick.identifyimagetype" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::identifyImageType</refname>
  <refpurpose>Gets the potential image type</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>int</type><methodname>Imagick::identifyImageType</methodname>
   <void/>
  </methodsynopsis>
  <simpara>Analyses the image and returns the classification that best describes its contents, such as bilevel, grayscale, palette or truecolor, optionally with an alpha channel.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns one of the <constant>Imagick::IMGTYPE_*</constant> constants describing the image type.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
