<refentry xml:id="imagick.cannyedgeimage" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>Imagick::cannyEdgeImage</refname>
  <refpurpose>Detect edges in the image using a Canny edge detector</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type><methodname>Imagick::cannyEdgeImage</methodname>
   <methodparam choice="opt"><type>float</type><parameter>radius</parameter><initializer>0.0</initializer></methodparam>
   <methodparam choice="opt"><type>float</type><parameter>sigma</parameter><initializer>1.0</initializer></methodparam>
   <methodparam choice="opt"><type>float</type><parameter>lower_percent</parameter><initializer>0.1</initializer></methodparam>
   <methodparam choice="opt"><type>float</type><parameter>upper_percent</parameter><initializer>0.3</initializer></methodparam>
  </methodsynopsis>
  <simpara>Applies a Canny edge detector to the image, producing a bilevel image in which detected edges are white and all other pixels are black.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>radius</parameter></term>
    <listitem>
     <simpara>The radius, in pixels, of the Gaussian smoothing applied before edge detection. A value of <literal>0</literal> lets ImageMagick choose a suitable radius from <parameter>sigma</parameter>.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>sigma</parameter></term>
    <listitem>
     <simpara>The standard deviation of the Gaussian smoothing, in pixels.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>lower_percent</parameter></term>
    <listitem>
     <simpara>The lower hysteresis threshold, as a fraction between <literal>0</literal> and <literal>1</literal>. Edges weaker than this are discarded.</simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>upper_percent</parameter></term>
    <listitem>
     <simpara>The upper hysteresis threshold, as a fraction between <literal>0</literal> and <literal>1</literal>. Edges stronger than this are kept as definite edges.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns &true; on success.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagick.throws;
  </simpara>
 </refsect1>
</refentry>
