<refentry xml:id="imagickpixel.setcolorfrompixel" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>ImagickPixel::setColorFromPixel</refname>
  <refpurpose>Sets the color of this object from another ImagickPixel object</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type> <methodname>ImagickPixel::setColorFromPixel</methodname>
   <methodparam><type>ImagickPixel</type><parameter>pixel</parameter></methodparam>
  </methodsynopsis>
  <simpara>Sets the color of this <classname>ImagickPixel</classname> object to the color held by the supplied <classname>ImagickPixel</classname> object.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>pixel</parameter></term>
    <listitem>
     <simpara>The <classname>ImagickPixel</classname> object whose color is copied.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>&return.success;</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagickpixel.throws;
  </simpara>
 </refsect1>
</refentry>

