<refentry xml:id="imagickpixeliterator.key" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>ImagickPixelIterator::key</refname>
  <refpurpose>Returns the row offset of the current pixel row</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>int</type> <methodname>ImagickPixelIterator::key</methodname>
   <void/>
  </methodsynopsis>
  <simpara>Returns the offset of the row the iterator currently points at. This method implements the <interfacename>Iterator</interfacename> interface.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the current row offset as an <type>int</type>.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagickpixeliterator.throws;
  </simpara>
 </refsect1>
</refentry>

