<refentry xml:id="imagickdraw.getopacity" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>ImagickDraw::getOpacity</refname>
  <refpurpose>Gets the opacity used when drawing</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>float</type> <methodname>ImagickDraw::getOpacity</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Returns the opacity currently applied to both fill and stroke colours when
   drawing.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns the opacity as a float between <literal>0.0</literal> (fully
   transparent) and <literal>1.0</literal> (fully opaque).
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagickdraw.throws;
  </simpara>
 </refsect1>
</refentry>
