<refentry xml:id="imagickdraw.gettextdirection" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>ImagickDraw::getTextDirection</refname>
  <refpurpose>Returns the direction that will be used when annotating with text</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>int</type> <methodname>ImagickDraw::getTextDirection</methodname>
   <void/>
  </methodsynopsis>
  <simpara>Returns the text direction that will be used when annotating with text.</simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>Returns the text direction as one of the <constant>Imagick::DIRECTION_*</constant> constants.</simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagickdraw.throws;
  </simpara>
 </refsect1>
</refentry>

