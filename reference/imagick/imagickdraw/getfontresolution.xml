<refentry xml:id="imagickdraw.getfontresolution" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>ImagickDraw::getFontResolution</refname>
  <refpurpose>Gets the font resolution used when annotating</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>array</type> <methodname>ImagickDraw::getFontResolution</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Returns the horizontal and vertical resolution, in dots per inch, used to
   rasterise text when annotating an image.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns an associative array with the keys <literal>x</literal> and
   <literal>y</literal>, holding the horizontal and vertical font resolution
   as floats.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagickdraw.throws;
  </simpara>
 </refsect1>
</refentry>
