<refentry xml:id="imagickdraw.setfontresolution" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>ImagickDraw::setFontResolution</refname>
  <refpurpose>Sets the font resolution used when annotating</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type> <methodname>ImagickDraw::setFontResolution</methodname>
   <methodparam><type>float</type><parameter>x</parameter></methodparam>
   <methodparam><type>float</type><parameter>y</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Sets the horizontal and vertical resolution, in dots per inch, used to
   rasterise text when annotating an image. Higher values produce more
   detailed glyphs.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>x</parameter></term>
    <listitem>
     <simpara>
      The horizontal resolution in dots per inch.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>y</parameter></term>
    <listitem>
     <simpara>
      The vertical resolution in dots per inch.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagickdraw.throws;
  </simpara>
 </refsect1>
</refentry>
