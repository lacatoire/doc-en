<refentry xml:id="imagickdraw.setopacity" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>ImagickDraw::setOpacity</refname>
  <refpurpose>Sets the opacity used when drawing</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>bool</type> <methodname>ImagickDraw::setOpacity</methodname>
   <methodparam><type>float</type><parameter>opacity</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Sets the opacity applied to both the fill and stroke colours of subsequent
   drawing operations, blending them with the underlying image.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>opacity</parameter></term>
    <listitem>
     <simpara>
      The opacity as a float between <literal>0.0</literal> (fully
      transparent) and <literal>1.0</literal> (fully opaque).
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns &true; on success.
  </simpara>
 </refsect1>
 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   &imagick.imagickdraw.throws;
  </simpara>
 </refsect1>
</refentry>
