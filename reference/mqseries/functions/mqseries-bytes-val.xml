<refentry xml:id="function.mqseries-bytes-val" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>mqseries_bytes_val</refname>
  <refpurpose>Returns the byte string contained in an MQSeries bytes resource</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type>string</type><methodname>mqseries_bytes_val</methodname>
   <methodparam><type>resource</type><parameter>bytes</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   <function>mqseries_bytes_val</function>
   returns the string of bytes contained in an MQSeries bytes resource, such as
   the message or correlation identifier returned in a message descriptor.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term>
     <parameter>bytes</parameter>
    </term>
    <listitem>
     <simpara>An MQSeries bytes resource.</simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns the string of bytes contained in the
   <parameter>bytes</parameter> resource, or &false; on failure.
  </simpara>
 </refsect1>

 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>mqseries_get</function></member>
   <member><function>mqseries_put</function></member>
  </simplelist>
 </refsect1>
</refentry>
