 <title>The Lua class</title>
 <titleabbrev>Lua</titleabbrev>

 <partintro>

<!-- {{{ Lua intro -->
  <section xml:id="lua.intro">
   &reftitle.intro;
   <simpara>

   </simpara>
  </section>
<!-- }}} -->

  <section xml:id="lua.synopsis">
   &reftitle.classsynopsis;

<!-- {{{ Synopsis -->
   <classsynopsis>
    <ooclass><classname>Lua</classname></ooclass>

<!-- {{{ Class synopsis -->
    <classsynopsisinfo>
     <ooclass>
      <classname>Lua</classname>
     </ooclass>
    </classsynopsisinfo>
<!-- }}} -->
    <classsynopsisinfo role="comment">&Constants;</classsynopsisinfo>
    <fieldsynopsis>
     <modifier>const</modifier>
     <type>string</type>
     <varname linkend="lua.constants.lua-version">Lua::LUA_VERSION</varname>
     <initializer>Lua 5.1.4</initializer>
    </fieldsynopsis>

    <classsynopsisinfo role="comment">&Methods;</classsynopsisinfo>
    <xi:include xpointer="xmlns(db=http://docbook.org/ns/docbook) xpointer(id('class.lua')/db:refentry/db:refsect1[@role='description']/descendant::db:methodsynopsis)"/>
   </classsynopsis>
<!-- }}} -->

  </section>


<!-- {{{ Lua constants -->
  <section xml:id="lua.constants">
   &reftitle.constants;
   <variablelist>

    <varlistentry xml:id="lua.constants.lua-version">
     <term><constant>Lua::LUA_VERSION</constant></term>
     <listitem>
      <simpara/>
     </listitem>
    </varlistentry>

    <varlistentry xml:id="lua.constants.lua-ok">
     <term><constant>LUA_OK</constant></term>
     <listitem>
      <simpara>No error.</simpara>
     </listitem>
    </varlistentry>

    <varlistentry xml:id="lua.constants.lua-yield">
     <term><constant>LUA_YIELD</constant></term>
     <listitem>
      <simpara>The thread (coroutine) yields.</simpara>
     </listitem>
    </varlistentry>

    <varlistentry xml:id="lua.constants.lua-errrun">
     <term><constant>LUA_ERRRUN</constant></term>
     <listitem>
      <simpara>A runtime error.</simpara>
     </listitem>
    </varlistentry>

    <varlistentry xml:id="lua.constants.lua-errsyntax">
     <term><constant>LUA_ERRSYNTAX</constant></term>
     <listitem>
      <simpara>A syntax error during compilation.</simpara>
     </listitem>
    </varlistentry>

    <varlistentry xml:id="lua.constants.lua-errmem">
     <term><constant>LUA_ERRMEM</constant></term>
     <listitem>
      <simpara>A memory allocation error.</simpara>
     </listitem>
    </varlistentry>

    <varlistentry xml:id="lua.constants.lua-errerr">
     <term><constant>LUA_ERRERR</constant></term>
     <listitem>
      <simpara>An error while running the message handler.</simpara>
     </listitem>
    </varlistentry>

    <varlistentry xml:id="lua.constants.lua-errfile">
     <term><constant>LUA_ERRFILE</constant></term>
     <listitem>
      <simpara>An error while loading a file.</simpara>
     </listitem>
    </varlistentry>

    <varlistentry xml:id="lua.constants.lua-errgcmm">
     <term><constant>LUA_ERRGCMM</constant></term>
     <listitem>
      <simpara>
       An error while running a <literal>__gc</literal> metamethod.
       Registered only when the linked Lua library defines it.
      </simpara>
     </listitem>
    </varlistentry>

   </variablelist>
  </section>
<!-- }}} -->


 </partintro>

 &reference.lua.entities.lua;

</reference>
