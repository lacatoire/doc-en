<refentry xml:id="iterator.key" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Iterator::key</refname>
  <refpurpose>Return the key of the current element</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis role="Iterator">
   <modifier>public</modifier> <type>mixed</type><methodname>Iterator::key</methodname>
   <void/>
  </methodsynopsis>
  <para>
   Returns the key of the current element.
  </para>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns the key of the current element. Can be of any type, but should be an
   <type>int</type> or a <type>string</type> if the key is to be used as an
   array offset (e.g. by <function>iterator_to_array</function>).
  </simpara>
 </refsect1>

</refentry>
